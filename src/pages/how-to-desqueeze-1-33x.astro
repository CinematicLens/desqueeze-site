---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import GuidesNavigator from '../components/GuidesNavigator.astro';
import { downloadAppsButtonClass } from '../data/siteNav';
import { lucideSvg } from '../lib/lucideSvg';
import { ChevronRight, Zap, Download, Repeat } from 'lucide';

const pageTitle = 'How to Desqueeze 1.33x Anamorphic Video | DeSqueeze Studio';
const pageDescription =
	'How to desqueeze 1.33× anamorphic video on iPhone and mobile rigs: confirm the lens, apply horizontal correction, and check faces and circles before export. Moment, Sirui, Moondog Labs-style workflows.';
const pageKeywords =
	'how to desqueeze 1.33x anamorphic video, 1.33x anamorphic desqueeze, mobile anamorphic lens desqueeze, iPhone anamorphic desqueeze, Moment Sirui Moondog Labs anamorphic correction';
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords}>
	<main class="min-h-dvh">
		<SiteHeader page="guides" />

		<section class="relative isolate overflow-hidden border-b border-white/10 bg-black">
			<div class="pointer-events-none absolute inset-0" aria-hidden="true">
				<div class="absolute inset-0 bg-[#060606]"></div>
				<div class="absolute inset-0 opacity-30 [background:radial-gradient(80%_60%_at_50%_10%,var(--color-accent-14),transparent_60%)]"></div>
			</div>

			<div class="page-shell relative z-10 py-14 md:py-20">
				<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] backdrop-blur-md md:p-8">
					<div
						class="pointer-events-none absolute left-1/2 top-16 h-[220px] w-[520px] -translate-x-1/2 rounded-full blur-3xl opacity-60 [background:radial-gradient(closest-side,var(--color-accent-18),transparent)]"
						aria-hidden="true"
					></div>

					<div class="relative grid gap-6 lg:grid-cols-[1.25fr_0.75fr] lg:items-start">
						<div class="min-w-0">
							<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">1.33× ANAMORPHIC GUIDE</p>
							<h1 class="mt-3 max-w-4xl text-balance text-3xl font-semibold tracking-tight text-white md:text-5xl">How to Desqueeze 1.33x Anamorphic Video</h1>
							<p class="mt-4 max-w-3xl text-pretty text-base leading-relaxed text-white/70 md:text-lg">
								1.33× footage is common with mobile anamorphic lenses and adapters (Moment, Sirui, Moondog Labs, and similar). If your video looks tall or squeezed,
								apply a 1.33× horizontal correction to restore natural proportions and cinematic framing.
							</p>

							<div class="mt-7 flex flex-col gap-3 sm:flex-row sm:items-center">
								<a class={`${downloadAppsButtonClass} gap-2`} href="/try-live">
									Try Web Studio
									<span set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
								</a>
								<a
									class="inline-flex items-center justify-center gap-2 self-start rounded-full border border-white/15 bg-white/[0.06] px-4 py-2 text-xs font-semibold text-white/90 hover:bg-white/[0.10] sm:self-auto"
									href="/products"
								>
									Explore Products
									<span class="text-white/55" set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
								</a>
							</div>

							<p class="mt-5 max-w-2xl text-sm text-white/55">
								Related:
								<a class="font-semibold text-[var(--color-accent)] underline-offset-2 hover:underline" href="/how-to-desqueeze-1-5x">1.5× guide</a>
								<span class="text-white/35"> · </span>
								<a class="font-semibold text-[var(--color-accent)] underline-offset-2 hover:underline" href="/fix-stretched-video">Fix stretched video</a>
								<span class="text-white/35"> · </span>
								<a class="font-semibold text-[var(--color-accent)] underline-offset-2 hover:underline" href="/desqueeze-video-online">Desqueeze video online</a>
							</p>
						</div>
					</div>

					<GuidesNavigator variant="mobile" />
				</div>
			</div>
		</section>

		<section class="page-shell py-12 md:py-16">
			<div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
				<div class="min-w-0 space-y-12 md:space-y-14">
					<section id="workflow" class="scroll-mt-28">
						<div class="flex flex-col gap-2">
							<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">1.33× WORKFLOW</p>
							<h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)] md:text-2xl">Correct mobile anamorphic footage without guessing.</h2>
						</div>

						<div class="mt-6 grid gap-3 md:grid-cols-[1fr_auto_1fr_auto_1fr_auto_1fr] md:items-stretch">
							<div class="rounded-3xl border border-[var(--color-accent-20)] bg-[var(--color-accent-06)] p-5 shadow-[0_0_0_1px_var(--color-accent-12),0_0_26px_var(--color-accent-12)]">
								<div class="flex items-start justify-between gap-4">
									<div class="min-w-0">
										<p class="text-xs font-semibold tracking-[0.18em] text-[var(--color-muted)]">STEP 1</p>
										<p class="mt-2 text-sm font-semibold text-[var(--color-text)]">Confirm the lens</p>
										<p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
											Check if the footage came from a 1.33× mobile anamorphic lens or adapter.
										</p>
									</div>
									<span class="shrink-0 text-[var(--color-accent)]" set:html={lucideSvg(Zap, 'h-5 w-5', 20)} aria-hidden="true"></span>
								</div>
							</div>

							<div class="hidden md:grid place-items-center px-1" aria-hidden="true">
								<span class="text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-6 w-6', 24)}></span>
							</div>

							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<div class="flex items-start justify-between gap-4">
									<div class="min-w-0">
										<p class="text-xs font-semibold tracking-[0.18em] text-[var(--color-muted-faint)]">STEP 2</p>
										<p class="mt-2 text-sm font-semibold text-[var(--color-text)]">Preview the frame</p>
										<p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
											Look at faces, circles, and vertical lines before export.
										</p>
									</div>
									<span class="shrink-0 text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-5 w-5', 20)} aria-hidden="true"></span>
								</div>
							</div>

							<div class="hidden md:grid place-items-center px-1" aria-hidden="true">
								<span class="text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-6 w-6', 24)}></span>
							</div>

							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<div class="flex items-start justify-between gap-4">
									<div class="min-w-0">
										<p class="text-xs font-semibold tracking-[0.18em] text-[var(--color-muted-faint)]">STEP 3</p>
										<p class="mt-2 text-sm font-semibold text-[var(--color-text)]">Apply 1.33×</p>
										<p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
											Stretch the image horizontally by 1.33× to restore the captured width.
										</p>
									</div>
									<span class="shrink-0 text-[var(--color-muted-faint)]" set:html={lucideSvg(Repeat, 'h-5 w-5', 20)} aria-hidden="true"></span>
								</div>
							</div>

							<div class="hidden md:grid place-items-center px-1" aria-hidden="true">
								<span class="text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-6 w-6', 24)}></span>
							</div>

							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<div class="flex items-start justify-between gap-4">
									<div class="min-w-0">
										<p class="text-xs font-semibold tracking-[0.18em] text-[var(--color-muted-faint)]">STEP 4</p>
										<p class="mt-2 text-sm font-semibold text-[var(--color-text)]">Choose delivery</p>
										<p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
											Export for widescreen, social crop, or editing handoff after the geometry is correct.
										</p>
									</div>
									<span class="shrink-0 text-[var(--color-muted-faint)]" set:html={lucideSvg(Download, 'h-5 w-5', 20)} aria-hidden="true"></span>
								</div>
							</div>
						</div>
					</section>

					<section class="scroll-mt-28">
						<div class="flex flex-col gap-2">
							<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">WHAT 1.33× DOES</p>
							<h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)] md:text-2xl">1.33× restores the width captured by the anamorphic lens.</h2>
						</div>

						<div class="mt-6 grid gap-4 md:grid-cols-3">
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Squeezed capture</p>
								<p class="mt-1 text-xs text-[var(--color-muted-faint)]">Before horizontal correction</p>
								<p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)]">
									The lens compresses horizontal information into the recorded frame.
								</p>
								<div class="mt-4 overflow-hidden rounded-2xl border border-[var(--color-border)] bg-black/60">
									<div class="relative aspect-[16/10]">
										<div class="absolute inset-0 opacity-70 [background:radial-gradient(80%_60%_at_50%_20%,rgba(255,255,255,0.10),transparent_60%)]"></div>
										<div class="absolute inset-y-0 left-1/2 w-px -translate-x-1/2 bg-[var(--color-accent-50)]"></div>
										<div class="absolute inset-y-0 left-[35%] w-px bg-white/10"></div>
										<div class="absolute inset-y-0 left-[65%] w-px bg-white/10"></div>
										<div class="absolute inset-x-0 top-[18%] h-px bg-white/10"></div>
										<div class="absolute inset-x-0 bottom-[18%] h-px bg-white/10"></div>
										<div class="absolute inset-0 [background:linear-gradient(90deg,rgba(255,255,255,0.02),transparent_26%,transparent_74%,rgba(255,255,255,0.02))]"></div>
									</div>
								</div>
							</div>

							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">1.33× correction</p>
								<p class="mt-1 text-xs text-[var(--color-muted-faint)]">Horizontal stretch, height unchanged</p>
								<p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)]">
									The preview stretches width by 1.33× while keeping height unchanged.
								</p>
								<div class="mt-4 overflow-hidden rounded-2xl border border-[var(--color-border)] bg-black/60">
									<div class="relative aspect-[16/10]">
										<div class="absolute inset-0 opacity-70 [background:radial-gradient(80%_60%_at_50%_20%,var(--color-accent-12),transparent_60%)]"></div>
										<div class="absolute inset-x-0 top-1/2 h-px -translate-y-1/2 bg-[var(--color-accent-50)]"></div>
										<div class="absolute inset-x-0 top-[35%] h-px bg-white/10"></div>
										<div class="absolute inset-x-0 top-[65%] h-px bg-white/10"></div>
										<div class="absolute inset-y-0 left-[18%] w-px bg-white/10"></div>
										<div class="absolute inset-y-0 right-[18%] w-px bg-white/10"></div>
										<div class="absolute inset-0 [background:linear-gradient(to_bottom,rgba(255,255,255,0.03),transparent_30%,transparent_70%,rgba(255,255,255,0.03))]"></div>
									</div>
								</div>
							</div>

							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Cinematic delivery</p>
								<p class="mt-1 text-xs text-[var(--color-muted-faint)]">After geometry is locked</p>
								<p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)]">
									After geometry is correct, choose widescreen, 16:9, or social framing.
								</p>
								<div class="mt-4 overflow-hidden rounded-2xl border border-[var(--color-border)] bg-black/60">
									<div class="relative aspect-[16/10]">
										<div class="absolute inset-0 opacity-70 [background:radial-gradient(80%_60%_at_50%_20%,rgba(255,255,255,0.08),transparent_60%)]"></div>
										<div class="absolute inset-x-0 top-0 h-[22%] bg-black/80"></div>
										<div class="absolute inset-x-0 bottom-0 h-[22%] bg-black/80"></div>
										<div class="absolute inset-x-0 bottom-[22%] h-px bg-[var(--color-accent-border)]"></div>
										<div class="absolute inset-0 [background:linear-gradient(to_bottom,transparent,rgba(0,0,0,0.20),transparent)]"></div>
									</div>
								</div>
							</div>
						</div>
					</section>

					<section class="scroll-mt-28">
						<div class="flex flex-col gap-2">
							<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">WHEN TO USE 1.33×</p>
							<h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)] md:text-2xl">Use 1.33× when the footage is lightly squeezed.</h2>
						</div>

						<div class="mt-6 grid gap-3 md:grid-cols-2 xl:grid-cols-3">
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Mobile anamorphic lenses</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">
									1.33× is common for phone-based anamorphic adapters and mobile filmmaking workflows.
								</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Footage looks tall</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">If people look thin or tall, 1.33× is often the first correction to test.</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Natural faces</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">After correction, faces should look natural — not wide, thin, or distorted.</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Circles stay circular</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">Wheels, lights, and round objects are good checks for correct geometry.</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Good for fast previews</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">1.33× is a reliable starting point when you are not sure of the lens value.</p>
							</div>
						</div>

						<div class="mt-4 rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface-strong)] p-5 text-sm text-[var(--color-muted)]">
							<p>
								<span class="font-semibold text-[var(--color-text)]">Quick check:</span> if 1.33× still looks squeezed, try 1.5× or 1.55×. If faces look too wide,
								reduce the factor.
							</p>
						</div>
					</section>

					<section class="scroll-mt-28">
						<div class="flex flex-col gap-2">
							<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">COMPARE RATIOS</p>
							<h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)] md:text-2xl">1.33× vs 1.5× vs 2×.</h2>
						</div>

						<div class="mt-6 grid gap-4 md:grid-cols-3">
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">1.33×</p>
								<p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
									Light squeeze, common for mobile anamorphic footage and quick cinematic framing.
								</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">1.5× / 1.55×</p>
								<p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
									Stronger correction, wider look, useful when 1.33× still appears squeezed.
								</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">2.0×</p>
								<p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
									Classic cinema-style anamorphic correction for heavily squeezed footage.
								</p>
							</div>
						</div>

						<p class="mt-5 text-sm text-[var(--color-muted)]">
							Next step for stronger squeeze:
							<a class="font-semibold text-[var(--color-accent)] underline-offset-2 hover:underline" href="/how-to-desqueeze-1-5x">1.5× guide</a>
							· Browser preview:
							<a class="font-semibold text-[var(--color-accent)] underline-offset-2 hover:underline" href="/desqueeze-video-online">Desqueeze online</a>
						</p>
					</section>

					<section class="scroll-mt-28">
						<div class="flex flex-col gap-2">
							<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">1.33× MISTAKES</p>
							<h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)] md:text-2xl">Common 1.33× desqueeze mistakes.</h2>
						</div>

						<div class="mt-6 grid gap-3 md:grid-cols-2">
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Using 1.5× on 1.33× footage</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">This can make faces and circles look too wide.</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Cropping before correction</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">Correct the geometry first. Crop only after the frame looks natural.</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Assuming all mobile lenses are 1.33×</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">Check the lens or app preset when possible. Some adapters use different values.</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Exporting without checking faces</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">Faces, wheels, and round lights reveal wrong correction faster than black bars.</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Judging only by letterbox bars</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">Bars can be normal in fit mode. Geometry is the real check.</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Mixing social crop with desqueeze</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">Desqueeze first, then create vertical, 16:9, or widescreen delivery versions.</p>
							</div>
						</div>
					</section>

					<section id="faq" class="scroll-mt-28">
						<div class="flex flex-col gap-2">
							<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">FAQ</p>
							<h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)] md:text-2xl">1.33× quick answers</h2>
						</div>

						<dl class="mt-6 space-y-5">
							<div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<dt class="text-sm font-semibold text-[var(--color-text)]">Is 1.33× the same as 2.39:1?</dt>
								<dd class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
									No. 1.33× is the squeeze correction. The final aspect ratio depends on the source frame and delivery crop.
								</dd>
							</div>
							<div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<dt class="text-sm font-semibold text-[var(--color-text)]">Why does 1.33× create black bars?</dt>

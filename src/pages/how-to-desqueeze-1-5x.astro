---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import GuidesNavigator from '../components/GuidesNavigator.astro';
import { downloadAppsButtonClass } from '../data/siteNav';
import { lucideSvg } from '../lib/lucideSvg';
import { ChevronRight, Zap, Download, Repeat } from 'lucide';

const pageTitle = 'How to Desqueeze 1.5x Anamorphic Video | DeSqueeze Studio';
const pageDescription =
	'How to desqueeze 1.5x and 1.55x anamorphic video: confirm the squeeze, compare values, check faces and circles, and export wider cinematic frames. Stronger correction than 1.33× — without over-stretching.';
const pageKeywords =
	'how to desqueeze 1.5x anamorphic video, how to desqueeze 1.55x anamorphic video, 1.5x anamorphic desqueeze, 1.55x anamorphic desqueeze, stronger anamorphic look, cinematic anamorphic correction';
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords}>
	<main class="min-h-dvh">
		<SiteHeader page="guides" />

		<section class="relative isolate overflow-hidden border-b border-white/10 bg-black">
			<div class="pointer-events-none absolute inset-0" aria-hidden="true">
				<div class="absolute inset-0 bg-[#060606]"></div>
				<div class="absolute inset-0 opacity-30 [background:radial-gradient(80%_60%_at_50%_10%,var(--color-accent-14),transparent_60%)]"></div>
			</div>

			<div class="page-shell relative z-10 py-14 md:py-20">
				<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] backdrop-blur-md md:p-8">
					<div
						class="pointer-events-none absolute left-1/2 top-16 h-[220px] w-[520px] -translate-x-1/2 rounded-full blur-3xl opacity-60 [background:radial-gradient(closest-side,var(--color-accent-18),transparent)]"
						aria-hidden="true"
					></div>

					<div class="relative grid gap-6 lg:grid-cols-[1.25fr_0.75fr] lg:items-start">
						<div class="min-w-0">
							<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">1.5× / 1.55× ANAMORPHIC GUIDE</p>
							<h1 class="mt-3 max-w-4xl text-balance text-3xl font-semibold tracking-tight text-white md:text-5xl">How to Desqueeze 1.5x Anamorphic Video</h1>
							<p class="mt-4 max-w-3xl text-pretty text-base leading-relaxed text-white/70 md:text-lg">
								1.5× and 1.55× footage gives a stronger widescreen look than 1.33×. Use the correct horizontal correction to restore natural geometry without making
								faces or objects look too wide.
							</p>

							<div class="mt-7 flex flex-col gap-3 sm:flex-row sm:items-center">
								<a class={`${downloadAppsButtonClass} gap-2`} href="/try-live">
									Try Web Studio
									<span set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
								</a>
								<a
									class="inline-flex items-center justify-center gap-2 self-start rounded-full border border-white/15 bg-white/[0.06] px-4 py-2 text-xs font-semibold text-white/90 hover:bg-white/[0.10] sm:self-auto"
									href="/products"
								>
									Explore Products
									<span class="text-white/55" set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
								</a>
							</div>

							<p class="mt-5 max-w-2xl text-sm text-white/55">
								Related:
								<a class="font-semibold text-[var(--color-accent)] underline-offset-2 hover:underline" href="/how-to-desqueeze-1-33x">1.33× guide</a>
								<span class="text-white/35"> · </span>
								<a class="font-semibold text-[var(--color-accent)] underline-offset-2 hover:underline" href="/fix-stretched-video">Fix stretched video</a>
								<span class="text-white/35"> · </span>
								<a class="font-semibold text-[var(--color-accent)] underline-offset-2 hover:underline" href="/desqueeze-video-online">Desqueeze video online</a>
							</p>
						</div>
					</div>

					<GuidesNavigator variant="mobile" />
				</div>
			</div>
		</section>

		<section class="page-shell py-12 md:py-16">
			<div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
				<div class="min-w-0 space-y-12 md:space-y-14">
					<section id="workflow" class="scroll-mt-28">
						<div class="flex flex-col gap-2">
							<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">1.5× WORKFLOW</p>
							<h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)] md:text-2xl">Correct stronger anamorphic footage with confidence.</h2>
						</div>

						<div class="mt-6 grid gap-3 md:grid-cols-[1fr_auto_1fr_auto_1fr_auto_1fr] md:items-stretch">
							<div class="rounded-3xl border border-[var(--color-accent-20)] bg-[var(--color-accent-06)] p-5 shadow-[0_0_0_1px_var(--color-accent-12),0_0_26px_var(--color-accent-12)]">
								<div class="flex items-start justify-between gap-4">
									<div class="min-w-0">
										<p class="text-xs font-semibold tracking-[0.18em] text-[var(--color-muted)]">STEP 1</p>
										<p class="mt-2 text-sm font-semibold text-[var(--color-text)]">Confirm the squeeze</p>
										<p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
											Check whether the footage was shot with a 1.5× or 1.55× anamorphic lens or preset.
										</p>
									</div>
									<span class="shrink-0 text-[var(--color-accent)]" set:html={lucideSvg(Zap, 'h-5 w-5', 20)} aria-hidden="true"></span>
								</div>
							</div>

							<div class="hidden md:grid place-items-center px-1" aria-hidden="true">
								<span class="text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-6 w-6', 24)}></span>
							</div>

							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<div class="flex items-start justify-between gap-4">
									<div class="min-w-0">
										<p class="text-xs font-semibold tracking-[0.18em] text-[var(--color-muted-faint)]">STEP 2</p>
										<p class="mt-2 text-sm font-semibold text-[var(--color-text)]">Test both values</p>
										<p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
											Compare 1.5× and 1.55× when the exact lens value is unclear.
										</p>
									</div>
									<span class="shrink-0 text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-5 w-5', 20)} aria-hidden="true"></span>
								</div>
							</div>

							<div class="hidden md:grid place-items-center px-1" aria-hidden="true">
								<span class="text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-6 w-6', 24)}></span>
							</div>

							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<div class="flex items-start justify-between gap-4">
									<div class="min-w-0">
										<p class="text-xs font-semibold tracking-[0.18em] text-[var(--color-muted-faint)]">STEP 3</p>
										<p class="mt-2 text-sm font-semibold text-[var(--color-text)]">Watch faces and circles</p>
										<p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
											Stronger factors can over-stretch quickly, so check natural geometry before export.
										</p>
									</div>
									<span class="shrink-0 text-[var(--color-muted-faint)]" set:html={lucideSvg(Repeat, 'h-5 w-5', 20)} aria-hidden="true"></span>
								</div>
							</div>

							<div class="hidden md:grid place-items-center px-1" aria-hidden="true">
								<span class="text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-6 w-6', 24)}></span>
							</div>

							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<div class="flex items-start justify-between gap-4">
									<div class="min-w-0">
										<p class="text-xs font-semibold tracking-[0.18em] text-[var(--color-muted-faint)]">STEP 4</p>
										<p class="mt-2 text-sm font-semibold text-[var(--color-text)]">Deliver wider frames</p>
										<p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
											Use the corrected image for cinematic widescreen, edit handoff, or final app export.
										</p>
									</div>
									<span class="shrink-0 text-[var(--color-muted-faint)]" set:html={lucideSvg(Download, 'h-5 w-5', 20)} aria-hidden="true"></span>
								</div>
							</div>
						</div>
					</section>

					<section class="scroll-mt-28">
						<div class="flex flex-col gap-2">
							<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">WHAT 1.5× DOES</p>
							<h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)] md:text-2xl">1.5× expands the frame more than 1.33×.</h2>
						</div>

						<div class="mt-6 grid gap-4 md:grid-cols-3">
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Stronger squeeze</p>
								<p class="mt-1 text-xs text-[var(--color-muted-faint)]">More width stored in-frame</p>
								<p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)]">
									1.5× footage stores more horizontal field of view inside the recorded frame.
								</p>
								<div class="mt-4 overflow-hidden rounded-2xl border border-[var(--color-border)] bg-black/60">
									<div class="relative aspect-[16/10]">
										<div class="absolute inset-0 opacity-70 [background:radial-gradient(80%_60%_at_50%_20%,rgba(255,255,255,0.10),transparent_60%)]"></div>
										<div class="absolute inset-y-0 left-1/2 w-px -translate-x-1/2 bg-[var(--color-accent-50)]"></div>
										<div class="absolute inset-y-0 left-[35%] w-px bg-white/10"></div>
										<div class="absolute inset-y-0 left-[65%] w-px bg-white/10"></div>
										<div class="absolute inset-x-0 top-[18%] h-px bg-white/10"></div>
										<div class="absolute inset-x-0 bottom-[18%] h-px bg-white/10"></div>
										<div class="absolute inset-0 [background:linear-gradient(90deg,rgba(255,255,255,0.02),transparent_26%,transparent_74%,rgba(255,255,255,0.02))]"></div>
									</div>
								</div>
							</div>

							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">1.5× / 1.55× correction</p>
								<p class="mt-1 text-xs text-[var(--color-muted-faint)]">More horizontal stretch than 1.33×</p>
								<p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)]">
									The preview stretches width more aggressively than 1.33× while keeping height unchanged.
								</p>
								<div class="mt-4 overflow-hidden rounded-2xl border border-[var(--color-border)] bg-black/60">
									<div class="relative aspect-[16/10]">
										<div class="absolute inset-0 opacity-70 [background:radial-gradient(80%_60%_at_50%_20%,var(--color-accent-12),transparent_60%)]"></div>
										<div class="absolute inset-x-0 top-1/2 h-px -translate-y-1/2 bg-[var(--color-accent-50)]"></div>
										<div class="absolute inset-x-0 top-[35%] h-px bg-white/10"></div>
										<div class="absolute inset-x-0 top-[65%] h-px bg-white/10"></div>
										<div class="absolute inset-y-0 left-[18%] w-px bg-white/10"></div>
										<div class="absolute inset-y-0 right-[18%] w-px bg-white/10"></div>
										<div class="absolute inset-0 [background:linear-gradient(to_bottom,rgba(255,255,255,0.03),transparent_30%,transparent_70%,rgba(255,255,255,0.03))]"></div>
									</div>
								</div>
							</div>

							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Wider delivery</p>
								<p class="mt-1 text-xs text-[var(--color-muted-faint)]">Cinematic, still natural</p>
								<p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)]">
									After correction, the frame can feel more cinematic, but must still preserve natural faces and shapes.
								</p>
								<div class="mt-4 overflow-hidden rounded-2xl border border-[var(--color-border)] bg-black/60">
									<div class="relative aspect-[16/10]">
										<div class="absolute inset-0 opacity-70 [background:radial-gradient(80%_60%_at_50%_20%,rgba(255,255,255,0.08),transparent_60%)]"></div>
										<div class="absolute inset-x-0 top-0 h-[22%] bg-black/80"></div>
										<div class="absolute inset-x-0 bottom-0 h-[22%] bg-black/80"></div>
										<div class="absolute inset-x-0 bottom-[22%] h-px bg-[var(--color-accent-border)]"></div>
										<div class="absolute inset-0 [background:linear-gradient(to_bottom,transparent,rgba(0,0,0,0.20),transparent)]"></div>
									</div>
								</div>
							</div>
						</div>
					</section>

					<section class="scroll-mt-28">
						<div class="flex flex-col gap-2">
							<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">WHEN TO USE 1.5×</p>
							<h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)] md:text-2xl">Use 1.5× or 1.55× when 1.33× is not enough.</h2>
						</div>

						<div class="mt-6 grid gap-3 md:grid-cols-2 xl:grid-cols-3">
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">1.33× still looks squeezed</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">If 1.33× correction still looks tall or narrow, test 1.5× next.</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Lens says 1.5×</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">If the lens or preset states 1.5×, use that value first.</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Lens says 1.55×</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">Some adapters and presets use 1.55×. Compare with 1.5× if unsure.</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Faces must stay natural</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">If faces look too wide, the correction is probably too strong.</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Better for wider looks</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">1.5× / 1.55× can create a more dramatic widescreen feel than 1.33×.</p>
							</div>
						</div>

						<div class="mt-4 rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface-strong)] p-5 text-sm text-[var(--color-muted)]">
							<p>
								<span class="font-semibold text-[var(--color-text)]">Quick check:</span> compare 1.5× and 1.55× using faces, wheels, lights, and straight vertical
								lines. Choose the value that looks natural, not just the widest.
							</p>
						</div>
					</section>

					<section class="scroll-mt-28">
						<div class="flex flex-col gap-2">
							<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">COMPARE RATIOS</p>
							<h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)] md:text-2xl">1.5× sits between mobile 1.33× and classic 2×.</h2>
						</div>

						<div class="mt-6 grid gap-4 md:grid-cols-3">
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">1.33×</p>
								<p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
									Lighter correction, common for mobile anamorphic footage and fast social workflows.
								</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-accent-20)] bg-[var(--color-accent-06)] p-5 shadow-[0_0_0_1px_var(--color-accent-12),0_0_22px_var(--color-accent-10)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">1.5× / 1.55×</p>
								<p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
									Stronger correction with a wider cinematic look while still being manageable for mobile or compact workflows.
								</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">2.0×</p>
								<p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
									Heavier correction used for classic cinema-style anamorphic footage and very wide framing.
								</p>
							</div>
						</div>

						<p class="mt-5 text-sm text-[var(--color-muted)]">
							Light-squeeze workflows:
							<a class="font-semibold text-[var(--color-accent)] underline-offset-2 hover:underline" href="/how-to-desqueeze-1-33x">1.33× guide</a>
							· Browser preview:
							<a class="font-semibold text-[var(--color-accent)] underline-offset-2 hover:underline" href="/desqueeze-video-online">Desqueeze online</a>
						</p>
					</section>

					<section class="scroll-mt-28">
						<div class="flex flex-col gap-2">
							<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">1.5× MISTAKES</p>
							<h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)] md:text-2xl">Common 1.5× / 1.55× desqueeze mistakes.</h2>
						</div>

						<div class="mt-6 grid gap-3 md:grid-cols-2">
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Treating 1.5× like 1.33×</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">A 1.5× lens needs stronger correction. 1.33× may still look squeezed.</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Over-correcting to 2×</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">2× can make 1.5× footage look unnaturally wide.</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Ignoring 1.55× presets</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">If your lens or app uses 1.55×, compare it against 1.5× before final export.</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Choosing the widest look</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">The correct factor is the one that restores natural geometry, not always the widest image.</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Checking only landscapes</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">Landscapes can hide distortion. Use faces, circles, and objects with known shapes.</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Exporting before comparison</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">Preview 1.5× and 1.55× side by side before committing to final output.</p>
							</div>
						</div>
					</section>

					<section id="faq" class="scroll-mt-28">
						<div class="flex flex-col gap-2">
							<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">FAQ</p>
							<h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)] md:text-2xl">1.5× / 1.55× quick answers</h2>
						</div>

						<dl class="mt-6 space-y-5">
							<div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<dt class="text-sm font-semibold text-[var(--color-text)]">Should I use 1.5× or 1.55×?</dt>
								<dd class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
									Use the lens or app preset value first. If unsure, compare both and choose the one where faces and circles look natural.
								</dd>
							</div>
							<div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<dt class="text-sm font-semibold text-[var(--color-text)]">Is 1.5× more cinematic than 1.33×?</dt>
								<dd class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
									It creates a stronger widescreen look, but the correct choice depends on the lens used during capture.
								</dd>
							</div>
							<div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<dt class="text-sm font-semibold text-[var(--color-text)]">What happens if I use 2× on 1.5× footage?</dt>
								<dd class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
									The image will usually look over-stretched, with faces and circular objects becoming too wide.
								</dd>
							</div>
							<div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<dt class="text-sm font-semibold text-[var(--color-text)]">Can I use 1.5× for mobile footage?</dt>
								<dd class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
									Yes, if the footage was captured with a 1.5× or 1.55× lens or preset. Do not use it just to make footage wider.
								</dd>
							</div>
						</dl>
					</section>

					<section class="scroll-mt-28">
						<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-[inset_0_1px_0_var(--color-border)] md:p-8">
							<div class="flex flex-col gap-2">
								<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">PREVIEW 1.5×</p>
								<h2 class="text-2xl font-semibold tracking-tight text-[var(--color-text)] md:text-3xl">Compare 1.5× and 1.55× before export.</h2>
								<p class="mt-1 max-w-2xl text-sm leading-relaxed text-[var(--color-muted)] md:text-base">
									Upload a frame or clip, preview both values, then continue in the app when you need final export, LUT grading, and batch workflows.
								</p>
							</div>

							<div class="mt-6 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
								<a class={`${downloadAppsButtonClass} gap-2`} href="/try-live">
									Try Web Studio
									<span set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
								</a>
								<a
									class="inline-flex items-center justify-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface-strong)] px-5 py-2.5 text-sm font-semibold text-[var(--color-text)] hover:bg-[var(--color-nav-hover-surface)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent-border)]"
									href="/products"
								>
									Explore Products
									<span class="text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
								</a>
							</div>
						</div>
					</section>
				</div>

				<aside class="hidden lg:block self-start justify-self-end lg:sticky lg:top-28 lg:border-l lg:border-[var(--color-border)] lg:pl-6 lg:pr-1">
					<div class="max-h-[calc(100vh-8.25rem)] overflow-auto pr-1 [scrollbar-width:thin] [scrollbar-color:var(--color-accent-border)_var(--color-scroll-track)]">
						<GuidesNavigator variant="desktop" />
					</div>
				</aside>
			</div>
		</section>

		<SiteFooter />
	</main>
</Layout>

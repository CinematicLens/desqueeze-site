---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { storeUrls } from '../data/storeUrls';
import { lucideSvg } from '../lib/lucideSvg';
import { ChevronRight } from 'lucide';

const pageTitle = 'Try Web Studio Live Preview | DeSqueeze Studio';
const pageDescription =
	'Upload squeezed footage, choose the squeeze factor, and preview the corrected frame instantly. Continue in app for export and advanced controls.';
const pageKeywords = 'try live preview, anamorphic desqueeze preview, desqueeze preview online, web studio live preview';
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords}>
	<main class="min-h-dvh">
		<SiteHeader page="try-live" />

		<section id="web-studio" class="page-shell scroll-mt-28 py-12 md:py-16" aria-label="Web Studio tool">
			<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-6 md:p-7" data-desqueeze-studio>
				<div class="flex flex-col gap-1">
					<p class="text-xs font-semibold tracking-[0.22em] text-[#FF7A1A]">WEB STUDIO</p>
					<h1 class="mt-1 text-xl font-semibold tracking-tight text-white md:text-2xl">Try Live Preview</h1>
				</div>

				<div class="mt-4 flex flex-wrap items-center gap-2 text-xs font-semibold text-white/65">
					<span class="rounded-full border border-white/10 bg-black/40 px-3 py-1">Upload</span>
					<span class="text-white/25" aria-hidden="true">→</span>
					<span class="rounded-full border border-white/10 bg-black/40 px-3 py-1">Choose factor</span>
					<span class="text-white/25" aria-hidden="true">→</span>
					<span class="rounded-full border border-white/10 bg-black/40 px-3 py-1">Preview</span>
					<span class="text-white/25" aria-hidden="true">→</span>
					<span class="rounded-full border border-white/10 bg-black/40 px-3 py-1">Export</span>
				</div>

				<div class="mt-6 grid gap-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
					<!-- LEFT: Live Preview + Files -->
					<div class="min-w-0 flex flex-col gap-4">
						<div class="relative overflow-hidden rounded-2xl border border-white/10 bg-black/40 shadow-[0_24px_70px_rgba(0,0,0,0.50)]">
							<div
								class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-200 ease-out [background:radial-gradient(60%_60%_at_50%_20%,rgba(255,122,26,0.22),transparent_58%)]"
								data-active-glow
								aria-hidden="true"
							></div>

							<div class="flex items-center justify-between gap-3 border-b border-white/10 px-5 py-4">
								<div class="min-w-0">
									<p class="inline-flex items-center gap-2 text-sm font-semibold text-white">
										<span class="relative inline-flex h-2.5 w-2.5">
											<span class="absolute inset-0 rounded-full bg-emerald-400/35 blur-[6px]" aria-hidden="true"></span>
											<span class="relative h-2.5 w-2.5 rounded-full bg-emerald-400 ring-1 ring-emerald-300/40" aria-hidden="true"></span>
										</span>
										Live Preview
									</p>
								</div>
							</div>

							<div class="p-5">
								<div
									class="group relative w-full overflow-hidden rounded-2xl border border-white/35 bg-black/60"
									style="aspect-ratio: var(--preview-aspect, 16 / 9);"
									data-preview-frame
								>
									<div class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-200 group-hover:opacity-100" aria-hidden="true">
										<div class="absolute inset-0 [background:linear-gradient(to_bottom,rgba(255,255,255,0.05),transparent_20%,transparent_80%,rgba(255,255,255,0.05))]"></div>
										<div class="absolute left-3 top-3 rounded-full border border-white/10 bg-black/50 px-2.5 py-1 text-[11px] font-semibold text-white/70">
											FPS <span data-fps-label>—</span>
										</div>
									</div>
									<div class="pointer-events-none absolute inset-0 opacity-0" data-fps-pulse aria-hidden="true"></div>

									<div class="absolute inset-0 overflow-hidden" data-preview-clip>
										<div
											class="absolute inset-0 min-h-0 origin-center will-change-transform"
											style="transform: scaleX(1); transform-origin: center; transition: transform 250ms ease;"
											data-preview
										>
											<video
												class="hidden block h-full w-full object-contain"
												playsinline
												muted
												loop
												autoplay
												preload="metadata"
												data-preview-video
											>
											</video>
											<img class="hidden block h-full w-full object-contain" alt="Preview" data-preview-image loading="lazy" decoding="async" />
											<div class="pointer-events-none absolute inset-0 grid place-items-center" data-preview-empty>
												<p class="rounded-full border border-white/15 bg-black/55 px-4 py-2 text-xs font-semibold tracking-[0.16em] text-white/70">
													UPLOAD IMAGE OR VIDEO TO PREVIEW
												</p>
											</div>
										</div>
									</div>

									<div class="pointer-events-none absolute inset-0 opacity-60 [background:radial-gradient(55%_55%_at_20%_18%,rgba(255,122,26,0.14),transparent_62%)]" aria-hidden="true"></div>
								</div>

								<div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
									<div class="flex flex-wrap items-center gap-2 invisible pointer-events-none" data-video-controls>
										<button
											type="button"
											class="inline-flex items-center justify-center gap-2 rounded-full border border-white/15 bg-white/[0.06] px-4 py-2 text-sm font-semibold text-white/90 hover:bg-white/[0.10] focus:outline-none focus:ring-2 focus:ring-white/30"
											data-play
										>
											Play
										</button>
										<button
											type="button"
											class="inline-flex items-center justify-center gap-2 rounded-full border border-white/15 bg-white/[0.06] px-4 py-2 text-sm font-semibold text-white/90 hover:bg-white/[0.10] focus:outline-none focus:ring-2 focus:ring-white/30"
											data-pause
										>
											Pause
										</button>
									</div>
								</div>
							</div>
						</div>

						<div class="flex flex-col rounded-2xl border border-white/10 bg-black/30 p-5" aria-label="Files">
							<div class="flex shrink-0 items-start justify-between gap-3">
								<div class="min-w-0">
									<p class="text-sm font-semibold text-white">Files</p>
									<p class="mt-1 text-xs text-white/60">Upload an image or video to preview.</p>
								</div>
								<div class="flex items-center gap-2">
									<button
										type="button"
										class="hidden rounded-full border border-white/15 bg-white/[0.06] px-4 py-2 text-sm font-semibold text-white/90 hover:bg-white/[0.10] focus:outline-none focus:ring-2 focus:ring-white/30"
										data-clear-files
									>
										Clear
									</button>
								</div>
							</div>

							<div
								class="mt-4 shrink-0 rounded-2xl border border-dashed border-white/15 bg-black/40 p-4 transition-colors hover:border-white/25 hover:bg-white/[0.04]"
								role="button"
								tabindex="0"
								data-dropzone
							>
								<input
									class="sr-only"
									type="file"
									accept=".jpg,.jpeg,.png,.webp,.mp4,.mov,.webm,video/mp4,video/webm,video/quicktime,image/jpeg,image/png,image/webp"
									multiple
									data-file-input
								/>
								<div class="flex items-start gap-3">
									<div class="mt-0.5 grid h-10 w-10 shrink-0 place-items-center rounded-2xl border border-white/10 bg-black/50 text-white/70" aria-hidden="true">
										<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
											<path d="M12 16V4" stroke-linecap="round"></path>
											<path d="M7 9l5-5 5 5" stroke-linecap="round" stroke-linejoin="round"></path>
											<path d="M4 20h16" stroke-linecap="round"></path>
										</svg>
									</div>
									<div class="min-w-0">
										<p class="text-sm font-semibold text-white">Drop files here or click to browse</p>
										<p class="mt-1 text-xs leading-relaxed text-white/60">Images or videos — keep one media type per batch</p>
									</div>
								</div>
							</div>

							<div class="mt-4 hidden shrink-0 rounded-2xl border border-amber-500/25 bg-amber-500/10 px-4 py-3 text-sm text-amber-100/90" data-mixed-error>
								Please upload either images or videos in one batch, not both.
							</div>

							<div class="file-list-scroll mt-4 min-h-0 max-h-[calc(2*3.5rem+0.5rem)] overflow-x-hidden overflow-y-auto pr-1">
								<div class="space-y-2" data-file-list>
									<p class="text-sm text-white/60">No files selected.</p>
								</div>
							</div>
						</div>
					</div>

					<!-- RIGHT: Settings + export -->
					<div class="min-w-0 flex flex-col gap-4">
						<div class="rounded-2xl border border-white/10 bg-black/30 p-5">
							<p class="text-sm font-semibold text-white">Settings</p>

							<div class="mt-5 grid gap-4">
								<div class="rounded-2xl border border-white/10 bg-black/40 p-4">
									<p class="text-xs font-semibold tracking-[0.16em] text-white/60">Pre-defined Squeeze Factor</p>
									<label class="sr-only" for="squeeze-factor">Pre-defined Squeeze Factor</label>
									<select
										id="squeeze-factor"
										class="mt-2 h-11 w-full rounded-xl border border-white/15 bg-black/50 px-3 text-sm text-white/90 outline-none ring-0 focus:border-[#FF7A1A]/50 focus:ring-2 focus:ring-[#FF7A1A]/25"
										data-ratio
									>
										<option value="1">None (1.00×)</option>
										<option value="1.25">1.25×</option>
										<option value="1.30">1.30×</option>
										<option value="1.33">1.33× Classic</option>
										<option value="1.35">1.35×</option>
										<option value="1.42">1.42×</option>
										<option value="1.45">1.45×</option>
										<option value="1.50">1.50×</option>
										<option value="1.55">1.55×</option>
										<option value="1.60">1.60×</option>
										<option value="1.66">1.66×</option>
										<option value="1.75">1.75×</option>
										<option value="1.80">1.80×</option>
										<option value="2.00">2.00×</option>
										<option value="custom">Custom</option>
									</select>
									<div class="hidden" data-custom-ratio-row>
										<div class="mt-2 grid grid-cols-[1fr_auto] items-center gap-2">
											<input
												class="h-11 w-full rounded-xl border border-white/15 bg-black/50 px-3 text-sm text-white/90 outline-none focus:border-[#FF7A1A]/50 focus:ring-2 focus:ring-[#FF7A1A]/25"
												type="number"
												inputmode="decimal"
												step="0.01"
												min="1"
												max="3"
												value="1.33"
												aria-label="Custom ratio"
												data-custom-ratio
											/>
											<span class="text-xs font-semibold text-white/55">×</span>
										</div>
										<p class="mt-2 text-xs text-white/55">Tip: Match your lens squeeze ratio for accurate framing.</p>
									</div>
								</div>

								<div class="rounded-2xl border border-white/10 bg-black/40 p-4">
									<p class="text-xs font-semibold tracking-[0.16em] text-white/60">Preview Mode</p>
									<p class="mt-2 text-xs text-white/55">Fit shows the full frame. True shows the real corrected width.</p>
									<div class="mt-3 grid grid-cols-2 gap-2" data-preview-mode>
										<button
											type="button"
											class="rounded-xl border border-[#FF7A1A]/35 bg-[#FF7A1A]/10 px-3 py-2 text-sm font-semibold text-[#FF7A1A] shadow-[0_0_0_1px_rgba(255,122,26,0.16),0_0_18px_rgba(255,122,26,0.10)] transition"
											data-preview-mode-btn="fit"
										>
											Fit to Screen
										</button>
										<button
											type="button"
											class="rounded-xl border border-white/10 bg-black/40 px-3 py-2 text-sm font-semibold text-white/70 transition hover:bg-white/[0.06]"
											data-preview-mode-btn="true"
										>
											True Desqueezed
										</button>
									</div>
								</div>

								<div
									class="hidden rounded-2xl border border-white/10 bg-black/40 p-4"
									data-conversion-inline
									aria-live="polite"
									aria-atomic="true"
								>
									<div class="flex items-center justify-between gap-3">
										<p class="text-xs font-semibold tracking-[0.16em] text-white/60">STATUS</p>
										<span class="inline-flex items-center gap-2 text-xs font-semibold text-emerald-300/90">
											<span class="relative inline-flex h-2.5 w-2.5">
												<span class="absolute inset-0 rounded-full bg-emerald-400/35 blur-[6px]" aria-hidden="true"></span>
												<span class="relative h-2.5 w-2.5 rounded-full bg-emerald-400 ring-1 ring-emerald-300/40" aria-hidden="true"></span>
											</span>
											Looks correct
										</span>
									</div>

									<p class="mt-4 text-sm font-semibold text-white" data-corrected-status>Corrected with —</p>

									<a
										class="mt-3 inline-flex w-full items-center justify-center gap-2 rounded-xl bg-[#FF7A1A] px-4 py-3 text-sm font-semibold text-black shadow-[0_0_0_1px_rgba(255,122,26,0.22),0_18px_50px_rgba(0,0,0,0.50)] transition hover:brightness-110 hover:shadow-[0_0_0_1px_rgba(255,122,26,0.28),0_0_28px_rgba(255,122,26,0.22),0_18px_50px_rgba(0,0,0,0.55)] focus:outline-none focus:ring-2 focus:ring-[#FF7A1A]/45"
										href={storeUrls.anamorphicApple}
										target="_blank"
										rel="noopener noreferrer"
									>
										Continue in App →
									</a>

									<p class="mt-2 text-xs text-white/60">Finish your video in the app with full cinematic control</p>
								</div>
							</div>
						</div>

						<!-- Exports are available in the app -->
					</div>
				</div>

				<div
					class="pointer-events-none fixed bottom-5 left-1/2 z-[60] w-[min(540px,calc(100vw-2.5rem))] -translate-x-1/2 opacity-0 transition-opacity duration-200"
					data-toast
					aria-live="polite"
					aria-atomic="true"
				>
					<div class="rounded-2xl border border-white/10 bg-black/80 px-4 py-3 text-sm text-white/80 backdrop-blur-xl shadow-[0_20px_60px_rgba(0,0,0,0.60)]">
						<span class="text-white" data-toast-title>Coming soon</span>
						<span class="ml-2 text-white/60" data-toast-body>Export will be available in the next update.</span>
					</div>
				</div>
			</div>

			<script is:inline>
				(() => {
					const root = document.querySelector('[data-desqueeze-studio]');
					if (!root) return;

					const preview = root.querySelector('[data-preview]');
					const previewFrame = root.querySelector('[data-preview-frame]');
					const previewClip = root.querySelector('[data-preview-clip]');
					const previewVideo = root.querySelector('[data-preview-video]');
					const previewImage = root.querySelector('[data-preview-image]');
					const previewEmpty = root.querySelector('[data-preview-empty]');
					const activeGlow = root.querySelector('[data-active-glow]');
					const fpsPulse = root.querySelector('[data-fps-pulse]');
					const fpsLabel = root.querySelector('[data-fps-label]');

					const conversionInline = root.querySelector('[data-conversion-inline]');
					const correctedStatus = root.querySelector('[data-corrected-status]');

					const ratioSelect = root.querySelector('[data-ratio]');
					const customRatioRow = root.querySelector('[data-custom-ratio-row]');
					const customRatioInput = root.querySelector('[data-custom-ratio]');
					const fpsSelect = root.querySelector('[data-fps]');
					const photoExport = root.querySelector('[data-photo-export]');
					const videoExport = root.querySelector('[data-video-export]');

					const fileInput = root.querySelector('[data-file-input]');
					const fileList = root.querySelector('[data-file-list]');
					const mixedError = root.querySelector('[data-mixed-error]');
					const dropzone = root.querySelector('[data-dropzone]');
					const clearBtn = root.querySelector('[data-clear-files]');

					const playBtn = root.querySelector('[data-play]');
					const pauseBtn = root.querySelector('[data-pause]');
					const videoControls = root.querySelector('[data-video-controls]');
					const previewModeRoot = root.querySelector('[data-preview-mode]');
					const previewModeFitBtn = root.querySelector('[data-preview-mode-btn="fit"]');
					const previewModeTrueBtn = root.querySelector('[data-preview-mode-btn="true"]');
					const toast = root.querySelector('[data-toast]');
					const toastTitle = root.querySelector('[data-toast-title]');
					const toastBody = root.querySelector('[data-toast-body]');

					let currentObjectUrl = null;
					let selectedIndex = -1;
					let files = [];
					let mediaKind = null; // 'image' | 'video' | null
					let previewMode = 'fit'; // 'fit' | 'true'
					let fpsTimer = null;
					let toastTimer = null;

					const clamp = (v, min, max) => Math.min(max, Math.max(min, v));

					const formatRatio = (v) => {
						const n = Number(v);
						if (!Number.isFinite(n)) return null;
						const s = n.toFixed(2).replace(/\.00$/, '');
						return `${s}x`;
					};

					const getSelectedRatioLabel = () => {
						if (!ratioSelect) return null;
						if (ratioSelect.value === 'custom') return formatRatio(customRatioInput ? customRatioInput.value : '1.33');
						return formatRatio(ratioSelect.value);
					};

					const setConversionVisible = (on) => {
						if (conversionInline instanceof HTMLElement) {
							conversionInline.classList.toggle('hidden', !on);
						}
					};

					const updateCorrectedStatus = () => {
						const label = getSelectedRatioLabel();
						if (!correctedStatus) return;
						correctedStatus.textContent = label ? `Corrected with ${label}` : 'Corrected with —';
					};

					const showToast = (title, body) => {
						if (!toast) return;
						if (toastTitle) toastTitle.textContent = title;
						if (toastBody) toastBody.textContent = body;
						toast.style.opacity = '1';
						clearTimeout(toastTimer);
						toastTimer = setTimeout(() => {
							toast.style.opacity = '0';
						}, 1400);
					};

					const flashActive = () => {
						if (!activeGlow) return;
						activeGlow.style.opacity = '1';
						window.clearTimeout(activeGlow.__t);
						activeGlow.__t = window.setTimeout(() => {
							activeGlow.style.opacity = '0';
						}, 220);
					};

					const getRatio = () => {
						let ratio = 1;

						if (ratioSelect && ratioSelect.value === 'custom') {
							const v = customRatioInput ? Number(customRatioInput.value) : 1.33;
							ratio = clamp(Number.isFinite(v) ? v : 1.33, 1, 3);
						} else if (ratioSelect) {
							ratio = Number(ratioSelect.value) || 1;
						}

						return ratio;
					};

					const getActiveMediaEl = () => {
						if (previewImage && !previewImage.classList.contains('hidden')) return previewImage;
						if (previewVideo && !previewVideo.classList.contains('hidden')) return previewVideo;
						return null;
					};

					const getMediaAspect = (el) => {
						if (!el) return null;
						if (el instanceof HTMLImageElement) {
							const w = el.naturalWidth || 0;
							const h = el.naturalHeight || 0;
							if (w > 0 && h > 0) return w / h;
						}
						if (el instanceof HTMLVideoElement) {
							const w = el.videoWidth || 0;
							const h = el.videoHeight || 0;
							if (w > 0 && h > 0) return w / h;
						}
						return null;
					};

					const applyDesqueezePreview = () => {
						if (!previewFrame) return;
						const mediaEl = getActiveMediaEl();
						if (!mediaEl) return;

						const rect = previewFrame.getBoundingClientRect();
						if (rect.width <= 0 || rect.height <= 0) return;

						const containerAspect = rect.width / rect.height;
						const mediaAspect = getMediaAspect(mediaEl);
						const factor = getRatio();

						mediaEl.style.boxShadow = '0 0 0 1px rgba(255,255,255,0.35) inset';

						if (previewClip instanceof HTMLElement) {
							previewClip.style.overflowY = 'hidden';
							previewClip.style.overflowX = previewMode === 'true' ? 'auto' : 'hidden';
						}

						if (previewMode === 'true') {
							const pxW = Math.max(1, Math.round(rect.width * factor));
							const pxH = Math.max(1, Math.round(rect.height));
							if (preview instanceof HTMLElement) {
								preview.style.width = `${pxW}px`;
								preview.style.height = `${pxH}px`;
							}
							mediaEl.style.position = 'relative';
							mediaEl.style.left = '';
							mediaEl.style.top = '';
							mediaEl.style.transformOrigin = 'left center';
							mediaEl.style.width = `${(100 / factor).toFixed(4)}%`;
							mediaEl.style.height = '100%';
							mediaEl.style.transform = `scaleX(${factor})`;
							if (previewClip instanceof HTMLElement) {
								previewClip.scrollLeft = Math.max(0, (previewClip.scrollWidth - previewClip.clientWidth) / 2);
							}
							flashActive();
							return;
						}

						if (preview instanceof HTMLElement) {
							preview.style.width = '100%';
							preview.style.height = '100%';
						}
						mediaEl.style.position = 'absolute';
						mediaEl.style.left = '50%';
						mediaEl.style.top = '50%';
						mediaEl.style.width = '100%';
						mediaEl.style.height = '100%';
						mediaEl.style.transformOrigin = 'center center';

						if (!mediaAspect || !Number.isFinite(mediaAspect)) {
							mediaEl.style.transform = `translate(-50%, -50%) scaleX(${factor})`;
							return;
						}

						const desqueezedAspect = mediaAspect * factor;
						const fitScale = desqueezedAspect > containerAspect ? containerAspect / desqueezedAspect : 1;
						mediaEl.style.transform = `translate(-50%, -50%) scaleX(${factor}) scale(${fitScale})`;
						flashActive();
					};

					const setMixedError = (on) => {
						if (!mixedError) return;
						mixedError.classList.toggle('hidden', !on);
					};

					const setExportUi = (kind) => {
						mediaKind = kind;
						if (photoExport) photoExport.classList.toggle('hidden', kind !== 'image');
						if (videoExport) videoExport.classList.toggle('hidden', kind !== 'video');
						if (videoControls) {
							videoControls.classList.toggle('invisible', kind !== 'video');
							videoControls.classList.toggle('pointer-events-none', kind !== 'video');
						}
					};

					const setClearVisible = (on) => {
						if (!clearBtn) return;
						clearBtn.classList.toggle('hidden', !on);
					};

					const stopFpsPulse = () => {
						if (fpsTimer) window.clearInterval(fpsTimer);
						fpsTimer = null;
						if (fpsPulse) fpsPulse.style.opacity = '0';
					};

					const startFpsPulse = (fps) => {
						stopFpsPulse();
						if (!fpsPulse) return;

						const periodMs = Math.max(16, Math.round(1000 / fps));
						let on = false;
						fpsTimer = window.setInterval(() => {
							on = !on;
							fpsPulse.style.opacity = on ? '0.16' : '0';
							fpsPulse.style.background =
								'linear-gradient(to bottom, rgba(255,255,255,0.08), transparent 22%, transparent 78%, rgba(255,255,255,0.08))';
						}, periodMs);
					};

					const applyFps = () => {
						if (!fpsSelect) return;
						const v = fpsSelect.value;
						if (fpsLabel) fpsLabel.textContent = v === 'keep' ? 'orig' : v;

						if (v === 'keep') {
							stopFpsPulse();
						} else {
							const fps = clamp(Number(v) || 24, 10, 120);
							startFpsPulse(fps);
						}
						flashActive();
					};

					const extOf = (name) => {
						const s = String(name || '');
						const i = s.lastIndexOf('.');
						return i >= 0 ? s.slice(i + 1).toLowerCase() : '';
					};

					const classifyFile = (file) => {
						const t = String(file?.type || '');
						if (t.startsWith('image/')) return 'image';
						if (t.startsWith('video/')) return 'video';
						const ext = extOf(file?.name);
						if (['jpg', 'jpeg', 'png', 'webp'].includes(ext)) return 'image';
						if (['mp4', 'mov', 'webm'].includes(ext)) return 'video';
						return null;
					};

					const setPreviewFromFile = (file) => {
						if (!previewVideo || !previewImage) return;
						if (previewEmpty) previewEmpty.classList.add('hidden');

						if (currentObjectUrl) URL.revokeObjectURL(currentObjectUrl);
						currentObjectUrl = URL.createObjectURL(file);

						const kind = classifyFile(file);
						const isVideo = kind === 'video';
						const isImage = kind === 'image';

						if (isVideo) {
							previewImage.classList.add('hidden');
							previewVideo.classList.remove('hidden');
							previewVideo.src = currentObjectUrl;
							previewVideo.load();
						} else if (isImage) {
							previewVideo.pause();
							previewVideo.removeAttribute('src');
							previewVideo.load();
							previewVideo.classList.add('hidden');
							previewImage.classList.remove('hidden');
							previewImage.src = currentObjectUrl;
						}
					};

					const renderFileList = () => {
						if (!fileList) return;
						if (!files.length) {
							fileList.innerHTML = '<p class="text-sm text-white/60">No files selected.</p>';
							selectedIndex = -1;
							setClearVisible(false);
							return;
						}

						const rows = files
							.map((f, i) => {
								const active = i === selectedIndex;
								const name = String(f.name || 'Untitled');
								const meta = f.type ? `${f.type}` : 'file';
								return `
									<button
										type="button"
										class="group flex min-h-[3.5rem] w-full items-center justify-between gap-3 rounded-xl border px-4 py-3 text-left transition-colors ${
											active
												? 'border-[#FF7A1A]/35 bg-[#FF7A1A]/10'
												: 'border-white/10 bg-black/40 hover:bg-white/[0.06]'
										}"
										data-file-row="${i}"
									>
										<span class="min-w-0">
											<span class="block truncate text-sm font-semibold ${active ? 'text-[#FF7A1A]' : 'text-white/85'}">${name}</span>
											<span class="mt-0.5 block truncate text-xs ${active ? 'text-[#FF7A1A]/80' : 'text-white/55'}">${meta}</span>
										</span>
										<span class="shrink-0 rounded-full border border-white/10 bg-black/30 px-2.5 py-1 text-[11px] font-semibold text-white/60">
											${active ? 'Selected' : 'Select'}
										</span>
									</button>
								`;
							})
							.join('');

						fileList.innerHTML = `<div class="grid gap-2">${rows}</div>`;
						setClearVisible(true);
					};

					const ensureSelected = (index) => {
						selectedIndex = clamp(index, 0, files.length - 1);
						renderFileList();
						setPreviewFromFile(files[selectedIndex]);
						applyDesqueezePreview();
						applyFps();
					};

					ratioSelect?.addEventListener('change', () => {
						const isCustom = ratioSelect.value === 'custom';
						customRatioRow?.classList.toggle('hidden', !isCustom);
						applyDesqueezePreview();
						updateCorrectedStatus();
					});
					customRatioInput?.addEventListener(
						'input',
						() => {
							applyDesqueezePreview();
							updateCorrectedStatus();
						},
						{ passive: true }
					);

					fpsSelect?.addEventListener('change', applyFps);

					const setPickedFiles = (picked) => {
						setMixedError(false);
						const supported = picked.filter((f) => classifyFile(f));
						const kinds = new Set(supported.map((f) => classifyFile(f)).filter(Boolean));

						if (kinds.size > 1) {
							setMixedError(true);
							showToast('Mixed media', 'Please upload one media type per batch.');
							return;
						}

						const kind = kinds.size === 1 ? Array.from(kinds)[0] : null;
						files = supported;
						setExportUi(kind);
						renderFileList();
						if (files.length) ensureSelected(0);
						else showToast('No files', 'Please pick an image or video.');
						setConversionVisible(files.length > 0);
						updateCorrectedStatus();
					};

					fileInput?.addEventListener('change', () => {
						const picked = Array.from(fileInput.files || []);
						if (!picked.length) return;
						setPickedFiles(picked);
					});

					fileList?.addEventListener('click', (e) => {
						const btn = e.target && e.target.closest ? e.target.closest('[data-file-row]') : null;
						if (!btn) return;
						const idx = Number(btn.getAttribute('data-file-row'));
						if (!Number.isFinite(idx)) return;
						ensureSelected(idx);
					});

					const clearAll = () => {
						setMixedError(false);
						files = [];
						selectedIndex = -1;
						setExportUi(null);
						renderFileList();
						if (fileInput) fileInput.value = '';
						if (currentObjectUrl) {
							URL.revokeObjectURL(currentObjectUrl);
							currentObjectUrl = null;
						}
						if (previewImage) {
							previewImage.src = '';
							previewImage.classList.add('hidden');
						}
						if (previewVideo) {
							previewVideo.pause();
							previewVideo.removeAttribute('src');
							previewVideo.load();
							previewVideo.classList.add('hidden');
						}
						if (previewEmpty) previewEmpty.classList.remove('hidden');
						applyDesqueezePreview();
						applyFps();
						setConversionVisible(false);
						updateCorrectedStatus();
					};

					clearBtn?.addEventListener('click', clearAll);

					const openPicker = () => fileInput && fileInput.click();
					dropzone?.addEventListener('click', openPicker);
					dropzone?.addEventListener('keydown', (e) => {
						if (e.key === 'Enter' || e.key === ' ') {
							e.preventDefault();
							openPicker();
						}
					});
					['dragenter', 'dragover'].forEach((evt) => {
						dropzone?.addEventListener(evt, (e) => {
							e.preventDefault();
							dropzone.classList.add('border-[#FF7A1A]/40', 'bg-[#FF7A1A]/[0.06]');
						});
					});
					['dragleave', 'drop'].forEach((evt) => {
						dropzone?.addEventListener(evt, (e) => {
							e.preventDefault();
							dropzone.classList.remove('border-[#FF7A1A]/40', 'bg-[#FF7A1A]/[0.06]');
						});
					});
					dropzone?.addEventListener('drop', (e) => {
						const dt = e.dataTransfer;
						if (!dt?.files?.length) return;
						setPickedFiles(Array.from(dt.files));
					});

					playBtn?.addEventListener('click', () => {
						if (!previewVideo || previewVideo.classList.contains('hidden')) return;
						previewVideo.play().catch(() => {});
						flashActive();
					});

					pauseBtn?.addEventListener('click', () => {
						if (!previewVideo || previewVideo.classList.contains('hidden')) return;
						previewVideo.pause();
						flashActive();
					});

					customRatioRow?.classList.add('hidden');
					setExportUi(null);
					setMixedError(false);
					setConversionVisible(false);
					updateCorrectedStatus();
					applyDesqueezePreview();
					applyFps();

					const setPreviewMode = (mode) => {
						previewMode = mode === 'true' ? 'true' : 'fit';
						if (previewModeFitBtn instanceof HTMLButtonElement) {
							const active = previewMode === 'fit';
							previewModeFitBtn.classList.toggle('border-[#FF7A1A]/35', active);
							previewModeFitBtn.classList.toggle('bg-[#FF7A1A]/10', active);
							previewModeFitBtn.classList.toggle('text-[#FF7A1A]', active);
							previewModeFitBtn.classList.toggle('shadow-[0_0_0_1px_rgba(255,122,26,0.16),0_0_18px_rgba(255,122,26,0.10)]', active);
							previewModeFitBtn.classList.toggle('border-white/10', !active);
							previewModeFitBtn.classList.toggle('bg-black/40', !active);
							previewModeFitBtn.classList.toggle('text-white/70', !active);
							previewModeFitBtn.classList.toggle('hover:bg-white/[0.06]', !active);
						}
						if (previewModeTrueBtn instanceof HTMLButtonElement) {
							const active = previewMode === 'true';
							previewModeTrueBtn.classList.toggle('border-[#FF7A1A]/35', active);
							previewModeTrueBtn.classList.toggle('bg-[#FF7A1A]/10', active);
							previewModeTrueBtn.classList.toggle('text-[#FF7A1A]', active);
							previewModeTrueBtn.classList.toggle('shadow-[0_0_0_1px_rgba(255,122,26,0.16),0_0_18px_rgba(255,122,26,0.10)]', active);
							previewModeTrueBtn.classList.toggle('border-white/10', !active);
							previewModeTrueBtn.classList.toggle('bg-black/40', !active);
							previewModeTrueBtn.classList.toggle('text-white/70', !active);
							previewModeTrueBtn.classList.toggle('hover:bg-white/[0.06]', !active);
						}
						applyDesqueezePreview();
					};

					if (previewModeRoot instanceof HTMLElement) {
						previewModeRoot.addEventListener('click', (e) => {
							const t = e.target;
							if (!(t instanceof Element)) return;
							const btn = t.closest('[data-preview-mode-btn]');
							if (!(btn instanceof HTMLElement)) return;
							const mode = btn.getAttribute('data-preview-mode-btn') || 'fit';
							setPreviewMode(mode);
						});
					}
					setPreviewMode('fit');

					previewImage?.addEventListener('load', applyDesqueezePreview, { passive: true });
					previewVideo?.addEventListener('loadedmetadata', applyDesqueezePreview, { passive: true });
					window.addEventListener('resize', applyDesqueezePreview, { passive: true });

					window.addEventListener(
						'beforeunload',
						() => {
							if (currentObjectUrl) URL.revokeObjectURL(currentObjectUrl);
						},
						{ once: true }
					);
				})();
			</script>
		</section>

		<SiteFooter />
	</main>
</Layout>

<style>
	[data-desqueeze-studio] select {
		color-scheme: dark;
	}
	[data-desqueeze-studio] select option {
		background: #0b0b0b;
		color: rgba(255, 255, 255, 0.92);
	}
	[data-desqueeze-studio] .file-list-scroll {
		scrollbar-width: thin;
		scrollbar-color: rgba(255, 122, 26, 0.35) rgba(255, 255, 255, 0.05);
	}
	[data-desqueeze-studio] .file-list-scroll::-webkit-scrollbar {
		width: 5px;
	}
	[data-desqueeze-studio] .file-list-scroll::-webkit-scrollbar-track {
		background: transparent;
	}
	[data-desqueeze-studio] .file-list-scroll::-webkit-scrollbar-thumb {
		background: rgba(255, 255, 255, 0.12);
		border-radius: 9999px;
	}
	[data-desqueeze-studio] .file-list-scroll::-webkit-scrollbar-thumb:hover {
		background: rgba(255, 122, 26, 0.35);
	}
</style>


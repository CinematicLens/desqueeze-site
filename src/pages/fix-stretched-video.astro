---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import GuidesNavigator from '../components/GuidesNavigator.astro';
import { downloadAppsButtonClass } from '../data/siteNav';
import { lucideSvg } from '../lib/lucideSvg';
import { ChevronRight, Zap, Repeat, Download } from 'lucide';

const pageTitle = 'Fix Stretched Video Online | DeSqueeze Studio';
const pageDescription =
	'Fix stretched or squeezed video online: diagnose wrong aspect ratio vs anamorphic squeeze, correct geometry without cropping first, and preview before export. Try Web Studio or DeSqueeze Studio apps.';
const pageKeywords =
	'fix stretched video, video looks stretched, fix squeezed video, wrong aspect ratio video, video looks tall or wide, desqueeze preview online';
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords}>
	<main class="min-h-dvh">
		<SiteHeader page="guides" />

		<section class="relative isolate overflow-hidden border-b border-white/10 bg-black">
			<div class="pointer-events-none absolute inset-0" aria-hidden="true">
				<div class="absolute inset-0 bg-[#060606]"></div>
				<div class="absolute inset-0 opacity-30 [background:radial-gradient(80%_60%_at_50%_10%,var(--color-accent-14),transparent_60%)]"></div>
			</div>

			<div class="page-shell relative z-10 py-14 md:py-20">
				<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] backdrop-blur-md md:p-8">
					<div
						class="pointer-events-none absolute left-1/2 top-16 h-[220px] w-[520px] -translate-x-1/2 rounded-full blur-3xl opacity-60 [background:radial-gradient(closest-side,var(--color-accent-18),transparent)]"
						aria-hidden="true"
					></div>

					<div class="relative grid gap-6 lg:grid-cols-[1.25fr_0.75fr] lg:items-start">
						<div class="min-w-0">
							<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">TROUBLESHOOTING GUIDE</p>
							<h1 class="mt-3 max-w-4xl text-balance text-3xl font-semibold tracking-tight text-white md:text-5xl">Fix Stretched Video Online</h1>
							<p class="mt-4 max-w-3xl text-pretty text-base leading-relaxed text-white/70 md:text-lg">
								Your video may look stretched because of anamorphic squeeze, wrong aspect ratio, export settings, or timeline scaling. Diagnose the problem
								first, then correct the frame without cropping.
							</p>

							<div class="mt-7 flex flex-col gap-3 sm:flex-row sm:items-center">
								<a class={`${downloadAppsButtonClass} gap-2`} href="/try-live">
									Try Web Studio
									<span set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
								</a>
								<a
									class="inline-flex items-center justify-center gap-2 self-start rounded-full border border-white/15 bg-white/[0.06] px-4 py-2 text-xs font-semibold text-white/90 hover:bg-white/[0.10] sm:self-auto"
									href="/products"
								>
									Explore Products
									<span class="text-white/55" set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
								</a>
							</div>

							<p class="mt-5 max-w-2xl text-sm text-white/55">
								Related:
								<a class="font-semibold text-[var(--color-accent)] underline-offset-2 hover:underline" href="/how-to-desqueeze-1-33x">How to Desqueeze 1.33×</a>
								<span class="text-white/35"> · </span>
								<a class="font-semibold text-[var(--color-accent)] underline-offset-2 hover:underline" href="/how-to-desqueeze-1-5x">How to Desqueeze 1.5×</a>
								<span class="text-white/35"> · </span>
								<a class="font-semibold text-[var(--color-accent)] underline-offset-2 hover:underline" href="/desqueeze-video-online">Desqueeze Video Online</a>
							</p>
						</div>
					</div>

					<GuidesNavigator variant="mobile" />
				</div>
			</div>
		</section>

		<section class="page-shell py-12 md:py-16">
			<div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
				<div class="min-w-0 space-y-12 md:space-y-14">
					<section id="workflow" class="scroll-mt-28">
						<div class="flex flex-col gap-2">
							<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">FIX THE PROBLEM</p>
							<h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)] md:text-2xl">Diagnose first, then correct the frame.</h2>
						</div>

						<div class="mt-6 grid gap-3 md:grid-cols-[1fr_auto_1fr_auto_1fr_auto_1fr] md:items-stretch">
							<div class="rounded-3xl border border-[var(--color-accent-20)] bg-[var(--color-accent-06)] p-5 shadow-[0_0_0_1px_var(--color-accent-12),0_0_26px_var(--color-accent-12)]">
								<div class="flex items-start justify-between gap-4">
									<div class="min-w-0">
										<p class="text-xs font-semibold tracking-[0.18em] text-[var(--color-muted)]">STEP 1</p>
										<p class="mt-2 text-sm font-semibold text-[var(--color-text)]">Identify the stretch</p>
										<p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
											Check if people look tall, wide, or if circles look oval.
										</p>
									</div>
									<span class="shrink-0 text-[var(--color-accent)]" set:html={lucideSvg(Zap, 'h-5 w-5', 20)} aria-hidden="true"></span>
								</div>
							</div>

							<div class="hidden md:grid place-items-center px-1" aria-hidden="true">
								<span class="text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-6 w-6', 24)}></span>
							</div>

							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<div class="flex items-start justify-between gap-4">
									<div class="min-w-0">
										<p class="text-xs font-semibold tracking-[0.18em] text-[var(--color-muted-faint)]">STEP 2</p>
										<p class="mt-2 text-sm font-semibold text-[var(--color-text)]">Check the source</p>
										<p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
											Was it shot with an anamorphic lens, phone adapter, or wrong timeline size?
										</p>
									</div>
									<span class="shrink-0 text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-5 w-5', 20)} aria-hidden="true"></span>
								</div>
							</div>

							<div class="hidden md:grid place-items-center px-1" aria-hidden="true">
								<span class="text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-6 w-6', 24)}></span>
							</div>

							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<div class="flex items-start justify-between gap-4">
									<div class="min-w-0">
										<p class="text-xs font-semibold tracking-[0.18em] text-[var(--color-muted-faint)]">STEP 3</p>
										<p class="mt-2 text-sm font-semibold text-[var(--color-text)]">Correct geometry</p>
										<p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
											Use the right desqueeze factor instead of cropping the image first.
										</p>
									</div>
									<span class="shrink-0 text-[var(--color-muted-faint)]" set:html={lucideSvg(Repeat, 'h-5 w-5', 20)} aria-hidden="true"></span>
								</div>
							</div>

							<div class="hidden md:grid place-items-center px-1" aria-hidden="true">
								<span class="text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-6 w-6', 24)}></span>
							</div>

							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<div class="flex items-start justify-between gap-4">
									<div class="min-w-0">
										<p class="text-xs font-semibold tracking-[0.18em] text-[var(--color-muted-faint)]">STEP 4</p>
										<p class="mt-2 text-sm font-semibold text-[var(--color-text)]">Preview before export</p>
										<p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
											Confirm faces, circles, and framing before saving or editing further.
										</p>
									</div>
									<span class="shrink-0 text-[var(--color-muted-faint)]" set:html={lucideSvg(Download, 'h-5 w-5', 20)} aria-hidden="true"></span>
								</div>
							</div>
						</div>
					</section>

					<section class="scroll-mt-28">
						<div class="flex flex-col gap-2">
							<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">WHY VIDEO LOOKS STRETCHED</p>
							<h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)] md:text-2xl">Stretch, squeeze, crop — know the difference.</h2>
						</div>

						<div class="mt-6 grid gap-4 md:grid-cols-3">
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Squeezed / Tall</p>
								<p class="mt-1 text-xs text-[var(--color-muted-faint)]">Still needs horizontal desqueeze</p>
								<p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)]">
									The image still needs horizontal desqueeze. People may look thin or tall.
								</p>
								<div class="mt-4 overflow-hidden rounded-2xl border border-[var(--color-border)] bg-black/60">
									<div class="relative aspect-[16/10]">
										<div class="absolute inset-0 opacity-70 [background:radial-gradient(80%_60%_at_50%_20%,rgba(255,255,255,0.10),transparent_60%)]"></div>
										<div class="absolute inset-y-0 left-1/2 w-px -translate-x-1/2 bg-[var(--color-accent-50)]"></div>
										<div class="absolute inset-y-0 left-[35%] w-px bg-white/10"></div>
										<div class="absolute inset-y-0 left-[65%] w-px bg-white/10"></div>
										<div class="absolute inset-x-0 top-[18%] h-px bg-white/10"></div>
										<div class="absolute inset-x-0 bottom-[18%] h-px bg-white/10"></div>
										<div class="absolute inset-0 [background:linear-gradient(90deg,rgba(255,255,255,0.02),transparent_26%,transparent_74%,rgba(255,255,255,0.02))]"></div>
									</div>
								</div>
							</div>

							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Over-stretched / Wide</p>
								<p class="mt-1 text-xs text-[var(--color-muted-faint)]">Factor may be too high</p>
								<p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)]">
									The factor may be too high. Faces and circles can look unnaturally wide.
								</p>
								<div class="mt-4 overflow-hidden rounded-2xl border border-[var(--color-border)] bg-black/60">
									<div class="relative aspect-[16/10]">
										<div class="absolute inset-0 opacity-70 [background:radial-gradient(80%_60%_at_50%_20%,var(--color-accent-12),transparent_60%)]"></div>
										<div class="absolute inset-x-0 top-1/2 h-px -translate-y-1/2 bg-[var(--color-accent-50)]"></div>
										<div class="absolute inset-x-0 top-[35%] h-px bg-white/10"></div>
										<div class="absolute inset-x-0 top-[65%] h-px bg-white/10"></div>
										<div class="absolute inset-y-0 left-[18%] w-px bg-white/10"></div>
										<div class="absolute inset-y-0 right-[18%] w-px bg-white/10"></div>
										<div class="absolute inset-0 [background:linear-gradient(to_bottom,rgba(255,255,255,0.03),transparent_30%,transparent_70%,rgba(255,255,255,0.03))]"></div>
									</div>
								</div>
							</div>

							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Cropped</p>
								<p class="mt-1 text-xs text-[var(--color-muted-faint)]">Geometry hidden, not fixed</p>
								<p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)]">
									Cropping hides parts of the frame. Fix geometry first, then crop for delivery.
								</p>
								<div class="mt-4 overflow-hidden rounded-2xl border border-[var(--color-border)] bg-black/60">
									<div class="relative aspect-[16/10]">
										<div class="absolute inset-0 opacity-70 [background:radial-gradient(80%_60%_at_50%_20%,rgba(255,255,255,0.08),transparent_60%)]"></div>
										<div class="absolute inset-x-0 top-0 h-[22%] bg-black/80"></div>
										<div class="absolute inset-x-0 bottom-0 h-[22%] bg-black/80"></div>
										<div class="absolute inset-x-0 bottom-[22%] h-px bg-[var(--color-accent-border)]"></div>
										<div class="absolute inset-0 [background:linear-gradient(to_bottom,transparent,rgba(0,0,0,0.20),transparent)]"></div>
									</div>
								</div>
							</div>
						</div>
					</section>

					<section class="scroll-mt-28">
						<div class="flex flex-col gap-2">
							<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">CHOOSE THE CORRECTION</p>
							<h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)] md:text-2xl">Which correction should you try?</h2>
						</div>

						<div class="mt-6 grid gap-3 md:grid-cols-2 xl:grid-cols-3">
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-xs font-semibold uppercase tracking-wide text-[var(--color-muted-faint)]">Symptom</p>
								<p class="mt-1 text-sm font-semibold text-[var(--color-text)]">People look tall/thin</p>
								<p class="mt-3 text-xs font-semibold uppercase tracking-wide text-[var(--color-accent)]">Try</p>
								<p class="mt-1 text-sm font-semibold text-[var(--color-text)]">Start with 1.33×</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">Common for mobile anamorphic footage.</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-xs font-semibold uppercase tracking-wide text-[var(--color-muted-faint)]">Symptom</p>
								<p class="mt-1 text-sm font-semibold text-[var(--color-text)]">Still looks squeezed after 1.33×</p>
								<p class="mt-3 text-xs font-semibold uppercase tracking-wide text-[var(--color-accent)]">Try</p>
								<p class="mt-1 text-sm font-semibold text-[var(--color-text)]">Test 1.5× or 1.55×</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">Stronger anamorphic lenses need more horizontal correction.</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-xs font-semibold uppercase tracking-wide text-[var(--color-muted-faint)]">Symptom</p>
								<p class="mt-1 text-sm font-semibold text-[var(--color-text)]">Faces look too wide</p>
								<p class="mt-3 text-xs font-semibold uppercase tracking-wide text-[var(--color-accent)]">Try</p>
								<p class="mt-1 text-sm font-semibold text-[var(--color-text)]">Lower the factor</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">You are likely over-desqueezing.</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-xs font-semibold uppercase tracking-wide text-[var(--color-muted-faint)]">Symptom</p>
								<p class="mt-1 text-sm font-semibold text-[var(--color-text)]">Circles look oval</p>
								<p class="mt-3 text-xs font-semibold uppercase tracking-wide text-[var(--color-accent)]">Try</p>
								<p class="mt-1 text-sm font-semibold text-[var(--color-text)]">Adjust factor until circles look natural</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">Circles, wheels, and faces are good visual checks.</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-xs font-semibold uppercase tracking-wide text-[var(--color-muted-faint)]">Symptom</p>
								<p class="mt-1 text-sm font-semibold text-[var(--color-text)]">Sides are missing</p>
								<p class="mt-3 text-xs font-semibold uppercase tracking-wide text-[var(--color-accent)]">Try</p>
								<p class="mt-1 text-sm font-semibold text-[var(--color-text)]">Remove crop/cover mode</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">Crop is not the same as desqueeze.</p>
							</div>
						</div>

						<div class="mt-4 rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface-strong)] p-5 text-sm text-[var(--color-muted)]">
							<p>
								<span class="font-semibold text-[var(--color-text)]">Quick check:</span> judge geometry by faces, circles, and vertical lines — not only by black
								bars.
							</p>
						</div>

						<p class="mt-5 text-sm text-[var(--color-muted)]">
							For step-by-step lens ratios, see
							<a class="font-semibold text-[var(--color-accent)] underline-offset-2 hover:underline" href="/how-to-desqueeze-1-33x">How to Desqueeze 1.33×</a>
							or
							<a class="font-semibold text-[var(--color-accent)] underline-offset-2 hover:underline" href="/how-to-desqueeze-1-5x">How to Desqueeze 1.5×</a>.
							For browser workflow details,
							<a class="font-semibold text-[var(--color-accent)] underline-offset-2 hover:underline" href="/desqueeze-video-online">Desqueeze Video Online</a>.
						</p>
					</section>

					<section class="scroll-mt-28">
						<div class="flex flex-col gap-2">
							<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">COMMON MISTAKES</p>
							<h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)] md:text-2xl">Fix stretched video mistakes to avoid.</h2>
						</div>

						<div class="mt-6 grid gap-3 md:grid-cols-2">
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Cropping before correcting</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">
									Cropping can hide the problem. Correct geometry first, then choose delivery framing.
								</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Using object-cover or fit-to-fill</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">
									Fill modes can stretch or crop the frame. Use contain-style preview when checking geometry.
								</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Guessing the factor randomly</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">
									Start with the lens value when known. If unknown, test 1.33× first and compare faces/circles.
								</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Exporting from the wrong timeline</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">
									A wrong canvas or aspect ratio can make a corrected video look stretched again.
								</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Judging only by black bars</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">
									Letterbox or pillarbox bars can be normal. Geometry matters more than bars.
								</p>
							</div>
							<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<p class="text-sm font-semibold text-[var(--color-text)]">Mixing social crop with correction</p>
								<p class="mt-2 text-sm text-[var(--color-muted)]">
									Fix the image first, then create 9:16, 16:9, or 2.39:1 delivery versions.
								</p>
							</div>
						</div>
					</section>

					<section id="faq" class="scroll-mt-28">
						<div class="flex flex-col gap-2">
							<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">FAQ</p>
							<h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)] md:text-2xl">Quick answers</h2>
						</div>

						<dl class="mt-6 space-y-5">
							<div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<dt class="text-sm font-semibold text-[var(--color-text)]">Is stretched video always anamorphic?</dt>
								<dd class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
									No. It can also come from wrong aspect ratio, timeline scaling, or export settings.
								</dd>
							</div>
							<div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<dt class="text-sm font-semibold text-[var(--color-text)]">Should I crop or desqueeze first?</dt>
								<dd class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
									Desqueeze first. Crop only after the image geometry looks correct.
								</dd>
							</div>
							<div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<dt class="text-sm font-semibold text-[var(--color-text)]">How do I know the right factor?</dt>
								<dd class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
									Use the lens value if known. Otherwise test 1.33×, then 1.5×/1.55×, and check faces or circular objects.
								</dd>
							</div>
							<div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-[inset_0_1px_0_var(--color-border)]">
								<dt class="text-sm font-semibold text-[var(--color-text)]">Why do I see black bars?</dt>
								<dd class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
									Black bars can appear naturally when the corrected frame is fitted inside a preview or delivery frame.
								</dd>
							</div>
						</dl>
					</section>

					<section class="scroll-mt-28">
						<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-[inset_0_1px_0_var(--color-border)] md:p-8">
							<div class="flex flex-col gap-2">
								<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">FIX BEFORE YOU EXPORT</p>
								<h2 class="text-2xl font-semibold tracking-tight text-[var(--color-text)] md:text-3xl">Correct the frame before you deliver.</h2>
								<p class="mt-1 max-w-2xl text-sm leading-relaxed text-[var(--color-muted)] md:text-base">
									Run a quick preview, confirm the geometry, then continue in the app for final export and advanced controls.
								</p>
							</div>

							<div class="mt-6 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
								<a class={`${downloadAppsButtonClass} gap-2`} href="/try-live">
									Try Web Studio
									<span set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
								</a>
								<a
									class="inline-flex items-center justify-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface-strong)] px-5 py-2.5 text-sm font-semibold text-[var(--color-text)] hover:bg-[var(--color-nav-hover-surface)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent-border)]"
									href="/products"
								>
									Explore Products
									<span class="text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
								</a>
							</div>
						</div>
					</section>
				</div>

				<aside class="hidden lg:block self-start justify-self-end lg:sticky lg:top-28 lg:border-l lg:border-[var(--color-border)] lg:pl-6 lg:pr-1">
					<div class="max-h-[calc(100vh-8.25rem)] overflow-auto pr-1 [scrollbar-width:thin] [scrollbar-color:var(--color-accent-border)_var(--color-scroll-track)]">
						<GuidesNavigator variant="desktop" />
					</div>
				</aside>
			</div>
		</section>

		<SiteFooter />
	</main>
</Layout>

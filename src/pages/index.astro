						</ul>

						<div class="mt-5 flex flex-col gap-2.5 sm:mt-6 sm:flex-row sm:items-center sm:flex-wrap sm:gap-3">
							<a class={heroPrimaryCtaClass} href="#suite" data-testid="cta-try-filmstudio">

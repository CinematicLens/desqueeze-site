				<script is:inline>
					(() => {
						const root = document.querySelector('[data-ecosystem-selector]');
						if (!root) return;
						const tabsWrap = root.querySelector('[data-ecosystem-tabs]');
						const tabs = tabsWrap ? Array.from(tabsWrap.querySelectorAll('[data-ecosystem-tab]')) : [];
						const panelsWrap = root.querySelector('[data-ecosystem-panels]');
						const panels = panelsWrap ? Array.from(panelsWrap.querySelectorAll('[data-ecosystem-panel]')) : [];
						if (tabs.length < 3 || panels.length < 3) return;

						const ACTIVE_TAB = [
							'border-transparent',
							'bg-black/55',
							'text-[#FF7A1A]',
							'shadow-[0_0_0_1px_rgba(255,122,26,0.16),0_0_22px_rgba(255,122,26,0.14)]',
						];
						const INACTIVE_TAB = ['border-transparent', 'bg-transparent', 'text-white/60'];

						const setActive = (key) => {
							panels.forEach((p) => {
								const k = p.getAttribute('data-ecosystem-panel');
								const active = k === key;
								p.classList.toggle('invisible', !active);
								p.classList.toggle('pointer-events-none', !active);
								p.classList.toggle('z-10', active);
								p.classList.toggle('z-0', !active);
								p.setAttribute('aria-hidden', active ? 'false' : 'true');
							});
							tabs.forEach((t) => {
								const k = t.getAttribute('data-ecosystem-tab');
								const isActive = k === key;
								t.setAttribute('aria-selected', isActive ? 'true' : 'false');
								t.classList.remove(...ACTIVE_TAB, ...INACTIVE_TAB);
								t.classList.add(...(isActive ? ACTIVE_TAB : INACTIVE_TAB));
							});
						};

						tabs.forEach((t) => {
							t.addEventListener('click', () => {
								const key = t.getAttribute('data-ecosystem-tab');
								if (!key) return;
								setActive(key);
							});
						});
					})();

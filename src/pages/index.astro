---
import { storeUrls } from '../data/storeUrls';
import { downloadAppsButtonClass, downloadAppsHref } from '../data/siteNav';
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { loadFilmStudioScreenshots } from '../lib/filmStudioScreenshots';
import { lucideSvg } from '../lib/lucideSvg';
import { fetchAppStoreMeta } from '../lib/storeMeta';
import { heroPrimaryCtaClass, heroSecondaryCtaClass } from '../lib/uiClasses';
import {
	Activity,
	Award,
	Box,
	Camera,
	Check,
	ChevronRight,
	CircleCheck,
	Clapperboard,
	ExternalLink,
	Globe,
	Package,
	Palette,
	Scan,
	Star,
	Target,
	Timer,
	Upload,
	Users,
	Zap,
} from 'lucide';

/** @param {string} s */
function decodeBasicEntities(s) {
	return s.replace(/&amp;/g, '&').replace(/&quot;/g, '"').replace(/&#39;/g, "'");
}

/**
 * Read Open Graph title/image from a public store HTML page (build-time).
 * @param {string} url
 * @returns {Promise<{ title: string | null; image: string | null } | null>}
 */
async function fetchOgMetaFromPage(url) {
	const ua =
		'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36';
	try {
		const res = await fetch(url, {
			headers: { 'User-Agent': ua, Accept: 'text/html,application/xhtml+xml' },
		});
		if (!res.ok) return null;
		const html = await res.text();
		const pick = (prop) => {
			const m1 = html.match(new RegExp(`<meta[^>]*\\sproperty=["']${prop}["'][^>]*\\scontent=["']([^"']+)["']`, 'i'));
			if (m1?.[1]) return decodeBasicEntities(m1[1]);
			const m2 = html.match(new RegExp(`<meta[^>]*\\scontent=["']([^"']+)["'][^>]*\\sproperty=["']${prop}["']`, 'i'));
			return m2?.[1] ? decodeBasicEntities(m2[1]) : null;
		};
		return { title: pick('og:title'), image: pick('og:image') };
	} catch {
		return null;
	}
}

/** @param {string} detailsUrl */
function playPackageIdFromDetailsUrl(detailsUrl) {
	try {
		return new URL(detailsUrl).searchParams.get('id') || '';
	} catch {
		return '';
	}
}

/** @param {string} detailsUrl storeUrls.android* */
async function fetchPlayStoreMetaFromDetailsUrl(detailsUrl) {
	const id = playPackageIdFromDetailsUrl(detailsUrl);
	if (!id) return null;
	const og = await fetchOgMetaFromPage(
		`https://play.google.com/store/apps/details?id=${encodeURIComponent(id)}&hl=en`,
	);
	if (!og?.title && !og?.image) return null;
	const name = (og.title || '')
		.replace(/\s*-\s*Apps on Google Play\s*$/i, '')
		.replace(/\s*-\s*Google Play\s*$/i, '')
		.trim();
	return { id, name, artworkUrl512: og.image || undefined };
}

/** @param {string} detailUrl e.g. storeUrls.windowsPro */
async function fetchMicrosoftStoreMetaFromDetailUrl(detailUrl) {
	const og = await fetchOgMetaFromPage(detailUrl);
	if (!og?.title && !og?.image) return null;
	const name = (og.title || '')
		.replace(/\s*-\s*Download.*$/i, '')
		.replace(/\s*\|\s*Microsoft Store\s*$/i, '')
		.trim();
	return { id: 'ms-store', name, artworkUrl512: og.image || undefined };
}

const filmStudioMeta = await fetchAppStoreMeta('6761248370');
const anamorphicMeta = await fetchAppStoreMeta('6757354068');
const mediaUtilityMeta = await fetchAppStoreMeta('6760351903');
const cineLutMeta = await fetchAppStoreMeta('6760215504');
const dmsMeta = await fetchAppStoreMeta('6761471161');

const androidDesqueezePlayMeta = await fetchPlayStoreMetaFromDetailsUrl(storeUrls.androidDesqueeze);
const androidProCamPlayMeta = await fetchPlayStoreMetaFromDetailsUrl(storeUrls.androidProCam);
const windowsStorePlayMeta = await fetchMicrosoftStoreMetaFromDetailUrl(storeUrls.windowsPro);

/** Landing hero full-bleed art (`public/images/background.png`). */
const landingHeroBgSrc = '/images/background.png';

/** Film Suite strip background (wide art; text/icons render on top). Replace `public/images/film-suite-hero-bg.png` to update. */
const filmSuiteHeroBgSrc = '/images/film-suite-hero-bg.png';

const suiteDemoPrimaryMp4 = '/film-suite-reel.mp4';
const suiteDemoFallbackMp4 = 'https://interactive-examples.mdn.mozilla.net/media/cc0-videos/flower.mp4';

const startHereCardBase =
	'group flex min-h-[3.75rem] items-center gap-3 rounded-2xl border px-3.5 py-2.5 transition hover:border-white/25 hover:bg-white/[0.04] sm:min-h-[4rem] sm:gap-4 sm:px-4 sm:py-3 md:px-5 lg:flex-1 lg:basis-0';

// FilmStudio UI screenshots: avoid brace-extension globs (can miss `.PNG` on Windows).
const filmStudioScreenshots = loadFilmStudioScreenshots();

---

<Layout>

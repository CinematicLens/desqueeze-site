				<div
					class="pointer-events-none absolute inset-0 z-[1] bg-no-repeat opacity-[0.52] sm:opacity-[0.56] [background-position:center_38%] max-md:bg-cover md:inset-auto md:top-0 md:right-0 md:bottom-0 md:left-[18%] md:opacity-[0.62] md:[background-size:auto_84%] md:[background-position:center_40%] lg:left-[14%] lg:[background-size:auto_88%] lg:[background-position:center_38%] xl:left-[10%] xl:[background-size:auto_94%] xl:[background-position:center_36%] 2xl:left-[4%] 2xl:[background-size:cover] 2xl:[background-position:center_34%]"
					style={`background-image: url('${landingHeroBgSrc}')`}
				></div>
				<div
					class="pointer-events-none absolute inset-0 z-[1] [background:linear-gradient(to_right,#060606_0%,rgba(6,6,6,0.94)_14%,rgba(6,6,6,0.55)_32%,rgba(6,6,6,0.12)_50%,transparent_70%)] md:[background:linear-gradient(to_right,#060606_0%,rgba(6,6,6,0.92)_10%,rgba(6,6,6,0.5)_24%,rgba(6,6,6,0.14)_40%,transparent_62%)]"
				></div>
				<div class="pointer-events-none absolute inset-0 z-[1] opacity-25 [background:radial-gradient(70%_65%_at_82%_42%,rgba(255,255,255,0.07),transparent_60%)]"></div>
				<div class="pointer-events-none absolute inset-0 z-[1] opacity-[0.18] [background:radial-gradient(48%_52%_at_88%_48%,rgba(255,122,26,0.12),transparent_58%)]"></div>
			</div>
			<div class="relative z-[2] page-shell pb-4 pt-6 sm:pt-8 md:pb-5 md:pt-10 lg:pt-8">
				<div
					class="relative w-full max-w-[680px] px-6 py-6 sm:px-10 sm:py-8 md:px-0 md:py-10 lg:py-8"
				>
						<p class="text-xs font-semibold tracking-[0.2em] text-[#FF7A1A]">FILMMAKING SUITE</p>
						<h1
							class="mt-3 max-w-[22ch] text-pretty text-[clamp(1.875rem,3.85vw,3rem)] font-semibold leading-[1.06] tracking-[-0.5px] text-white sm:max-w-none lg:mt-3.5"
						>
							<span class="block text-white">Shoot with confidence.</span>
							<span class="mt-1 block text-white sm:mt-1.5">Deliver the look you imagined.</span>
						</h1>
						<p class="mt-3 max-w-[48ch] text-pretty text-sm leading-snug text-white/72 sm:text-base md:mt-3.5 md:text-base md:leading-relaxed">
							Monitor. Control. Lock your look — before it's too late.
						</p>

						<ul class="mt-4 max-w-[52ch] space-y-2.5 text-sm leading-snug text-white/88 sm:space-y-3 md:mt-5 md:text-[0.95rem]" aria-label="Key capabilities">
							<li class="flex gap-3.5">
								<span class="mt-0.5 shrink-0" aria-hidden="true">
									<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
										<rect x="3.5" y="9" width="9.5" height="11.5" rx="1.25" stroke="#FF7A1A" stroke-width="2"></rect>
										<rect x="11" y="3" width="9.5" height="9.5" rx="1.25" stroke="#FF7A1A" stroke-width="2"></rect>
									</svg>
								</span>
								<span>Live desqueeze preview for accurate framing</span>
							</li>
							<li class="flex gap-3.5">
								<span class="mt-0.5 shrink-0" aria-hidden="true">
									<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
										<rect x="3" y="3" width="18" height="18" rx="2" stroke="#FF7A1A" stroke-width="2"></rect>
										<path
											d="M7 14.5 L9.5 11l2.5 3 3.5-5.5L17 14"
											stroke="#FF7A1A"
											stroke-width="2"
											stroke-linecap="round"
											stroke-linejoin="round"></path>
									</svg>
								</span>
								<span>Real-time LUT + scopes for confident exposure</span>
							</li>
							<li class="flex gap-3.5">

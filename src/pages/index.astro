							src={filmSuiteHeroBgSrc}
							alt=""
							class="absolute right-0 top-1/2 z-0 h-[calc(100%+10px)] w-[calc(100%+32px)] max-w-none -translate-y-1/2 object-cover object-right md:h-[calc(100%+12px)] md:w-[calc(100%+40px)]"

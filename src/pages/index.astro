					<div
						class="relative z-10 flex min-h-[124px] flex-row flex-wrap items-center gap-x-5 gap-y-3 px-5 py-3.5 sm:gap-x-7 sm:px-6 md:min-h-[136px] md:gap-x-10 md:px-8 md:py-4 lg:px-10"
					>
						<div class="shrink-0">
							<p class="text-xl font-bold tracking-[0.28em] text-white sm:text-2xl md:tracking-[0.34em]">FILM SUITE</p>
							<p
								class="mt-1.5 text-[10px] font-semibold leading-relaxed tracking-[0.24em] text-[rgb(255,106,0)] sm:text-[11px] md:mt-2 md:tracking-[0.28em]"

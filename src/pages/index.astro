						</div>
						<div
							class="absolute inset-0 z-[1] opacity-90 mix-blend-soft-light md:opacity-100 [background:radial-gradient(ellipse_48%_72%_at_90%_50%,rgba(255,180,80,0.09),transparent_58%)]"
						>

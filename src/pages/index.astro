								<span set:html={lucideSvg(ChevronRight, 'h-4 w-4 shrink-0 opacity-95', 16)} aria-hidden="true"></span>
							</a>
							<a class={heroSecondaryCtaClass} href="#suite-apps">
								<span>Explore suite apps</span>
								<span set:html={lucideSvg(ChevronRight, 'h-4 w-4 shrink-0 opacity-95', 16)} aria-hidden="true"></span>
							</a>
						
						</div>

						<p class="mt-4 flex flex-wrap items-center gap-2 text-xs font-medium leading-relaxed text-[#FF7A1A] sm:mt-5 sm:text-sm">
							<svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
								<path
									d="M12 3.5l1.8 4.1 4.5.4-3.4 3 1 4.4L12 14.2 7.1 15.4l1-4.4-3.4-3 4.5-.4L12 3.5z"
									stroke-linejoin="round"></path>

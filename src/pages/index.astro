						</p>
				</div>
			</div>

			<div class="relative z-[2] page-shell px-6 pb-1 pt-2 sm:px-10 sm:pb-2 sm:pt-3 md:pb-3 md:pt-4">
				<div
					class="flex flex-col gap-3 rounded-2xl border border-white/10 bg-white/[0.035] p-3 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] backdrop-blur-md sm:gap-4 sm:p-4 md:flex-row md:flex-wrap md:items-center md:gap-x-8 md:gap-y-3 md:p-4 lg:gap-x-10"
				>
					<div class="flex shrink-0 items-center gap-3">
						<p class="text-[11px] font-semibold tracking-[0.22em] text-white/50">TRUSTED BY FILMMAKERS</p>
						<span class="hidden h-5 w-px bg-white/20 md:inline-block" aria-hidden="true"></span>
					</div>
					<div class="flex flex-1 flex-wrap items-center gap-x-5 gap-y-2 text-xs font-medium text-white/92 sm:gap-x-6 sm:gap-y-3 sm:text-sm md:gap-x-8">
						<span class="inline-flex items-center gap-2.5">
							<span class="text-[#FF7A1A]" set:html={lucideSvg(Scan, 'h-5 w-5 shrink-0', 20)} aria-hidden="true"></span>
							Accurate Framing
						</span>
						<span class="inline-flex items-center gap-2.5">
							<span class="text-[#FF7A1A]" set:html={lucideSvg(Activity, 'h-5 w-5 shrink-0', 20)} aria-hidden="true"></span>
							Real-time Monitoring
						</span>
						<span class="inline-flex items-center gap-2.5">
							<svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
								<circle cx="9" cy="11" r="4.5" stroke="#FF7A1A" stroke-width="1.75"></circle>
								<circle cx="15" cy="11" r="4.5" stroke="#FF7A1A" stroke-width="1.75"></circle>
								<circle cx="12" cy="14.5" r="4.5" stroke="#FF7A1A" stroke-width="1.75"></circle>
							</svg>
							Cinematic Color
						</span>
						<span class="inline-flex items-center gap-2.5">
							<span class="text-[#FF7A1A]" set:html={lucideSvg(Zap, 'h-5 w-5 shrink-0', 20)} aria-hidden="true"></span>
							Faster Workflow
						</span>
						<span class="inline-flex items-center gap-2.5">
							<span class="text-[#FF7A1A]" set:html={lucideSvg(Clapperboard, 'h-5 w-5 shrink-0', 20)} aria-hidden="true"></span>
							Production Ready
						</span>
					</div>
				</div>
			</div>

			<div class="relative z-[2] page-shell px-6 pb-10 pt-3 sm:px-10 sm:pb-12 sm:pt-4 md:pb-14 md:pt-5">
				<div
					class="flex flex-col gap-3 rounded-2xl border border-white/10 bg-white/[0.035] p-3 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] sm:gap-4 sm:p-4 lg:flex-row lg:items-stretch lg:gap-5 lg:p-4"
				>
					<div class="flex w-max shrink-0 flex-col justify-center gap-1 pr-2 lg:pr-4">
						<h2 class="whitespace-nowrap text-base font-semibold tracking-tight text-white sm:text-lg md:text-xl lg:text-2xl">Start in 10 sec</h2>
						<p class="text-xs leading-snug text-white/55 sm:text-sm">What are you trying to do right now?</p>
					</div>
					<div class="grid min-w-0 flex-1 grid-cols-1 gap-2.5 sm:grid-cols-2 lg:flex lg:grid-cols-none lg:flex-nowrap lg:gap-2.5">
						<a
							href="/products#anamorphic"
							class={`${startHereCardBase} border-sky-500/25 bg-sky-500/[0.06]`}
						>
							<span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-sky-500/15 text-sky-400" set:html={lucideSvg(Activity, 'h-5 w-5', 20)} aria-hidden="true"></span>
							<span class="min-w-0 flex-1">
								<span class="block text-xs text-white/65">Fix anamorphic</span>
								<span class="block text-sm font-semibold text-sky-300">Desqueeze</span>
							</span>
							<span class="text-white/40 group-hover:text-white/70" set:html={lucideSvg(ChevronRight, 'h-5 w-5 shrink-0', 20)} aria-hidden="true"></span>
						</a>
						<a
							href="/products#filmstudio"
							class={`${startHereCardBase} min-h-0 min-w-0 border-[rgba(255,122,26,0.28)] bg-[rgba(255,122,26,0.08)]`}
						>
							<span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[rgba(255,122,26,0.12)] text-[#FF7A1A]" set:html={lucideSvg(Camera, 'h-5 w-5', 20)} aria-hidden="true"></span>
							<span class="min-w-0 flex-1">
								<span class="block text-xs text-white/65">I want to shoot</span>
								<span class="block text-sm font-semibold text-[#FF7A1A]">FilmStudio</span>
							</span>
							<span class="text-white/40 group-hover:text-white/70" set:html={lucideSvg(ChevronRight, 'h-5 w-5 shrink-0', 20)} aria-hidden="true"></span>
						</a>
						<a
							href="/products#cinelut"
							class={`${startHereCardBase} border-violet-500/25 bg-violet-500/[0.07]`}
						>
							<span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-violet-500/15 text-violet-300" set:html={lucideSvg(Box, 'h-5 w-5', 20)} aria-hidden="true"></span>
							<span class="min-w-0 flex-1">
								<span class="block text-xs text-white/65">Color grade</span>
								<span class="block text-sm font-semibold text-violet-300">CineLut</span>
							</span>
							<span class="text-white/40 group-hover:text-white/70" set:html={lucideSvg(ChevronRight, 'h-5 w-5 shrink-0', 20)} aria-hidden="true"></span>
						</a>
						<a
							href="/#suite-apps"
							class={`${startHereCardBase} border-emerald-500/25 bg-emerald-500/[0.07]`}
						>
							<span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-emerald-500/15 text-emerald-300" set:html={lucideSvg(Upload, 'h-5 w-5', 20)} aria-hidden="true"></span>
							<span class="min-w-0 flex-1">
								<span class="block text-xs text-white/65">Export / compress</span>
								<span class="block text-sm font-semibold text-emerald-300">MediaUtility</span>
							</span>
							<span class="text-white/40 group-hover:text-white/70" set:html={lucideSvg(ChevronRight, 'h-5 w-5 shrink-0', 20)} aria-hidden="true"></span>
						</a>
					</div>
				</div>
			</div>
		</section>

		<section id="suite" class="scroll-mt-24 page-shell py-16 md:scroll-mt-28 md:py-24">
			<div class="rounded-[28px] border border-white/10 bg-[#0a0a0a] p-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] md:p-8 lg:p-10">
				<div class="relative mb-10 min-h-[124px] overflow-hidden rounded-2xl border border-white/10 bg-black md:mb-11 md:min-h-[136px]">

							class="absolute inset-0 z-[1] bg-gradient-to-b from-black via-black/78 to-black/92 md:bg-gradient-to-r md:from-[#0a0a0a] md:from-0% md:via-[#0a0a0a]/96 md:via-[52%] md:to-transparent"

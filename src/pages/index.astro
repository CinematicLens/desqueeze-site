				<script is:inline>
					(() => {
						const root = document.querySelector('[data-workflow-pause-area]');
						const pipeline = root?.querySelector('[data-workflow-pipeline]');
						const steps = pipeline?.querySelector('[data-workflow-steps]');
						if (!root || !pipeline || !steps) return;

						const reduceMotion = window.matchMedia?.('(prefers-reduced-motion: reduce)')?.matches ?? false;
						const cards = Array.from(steps.querySelectorAll('[data-step-card]'));
						const arrows = Array.from(steps.querySelectorAll('[data-step-arrow]'));
						const detailCards = Array.from(root.querySelectorAll('[data-detail-card]'));
						const dotsWrap = root.querySelector('[data-workflow-dots]');
						const dots = dotsWrap ? Array.from(dotsWrap.querySelectorAll('[data-dot]')) : [];
						if (cards.length < 4) return;

						const ACTIVE_CARD = ['scale-[1.02]', 'opacity-100'];
						const INACTIVE_CARD = ['opacity-55', 'scale-100', 'shadow-none', 'border-white/10', 'bg-black/20'];
						const STEP_ACCENT = [
							[
								'border-[#FF7A1A]/50',
								'bg-[#FF7A1A]/[0.06]',
								'shadow-[0_0_0_1px_rgba(255,122,26,0.18),0_0_26px_rgba(255,122,26,0.14)]'
							],
							[
								'border-sky-500/40',
								'bg-sky-500/[0.08]',
								'shadow-[0_0_0_1px_rgba(56,189,248,0.16),0_0_26px_rgba(56,189,248,0.12)]'
							],
							[
								'border-fuchsia-500/35',
								'bg-fuchsia-500/[0.08]',
								'shadow-[0_0_0_1px_rgba(217,70,239,0.16),0_0_26px_rgba(217,70,239,0.12)]'
							],
							[
								'border-emerald-500/35',
								'bg-emerald-500/[0.08]',
								'shadow-[0_0_0_1px_rgba(16,185,129,0.16),0_0_26px_rgba(16,185,129,0.12)]'
							]
						];
						const BADGE_ACTIVE = [
							['border-[#FF7A1A]/40', 'text-[#FF7A1A]'],
							['border-sky-500/35', 'text-sky-300'],
							['border-fuchsia-500/30', 'text-fuchsia-300'],
							['border-emerald-500/30', 'text-emerald-300']
						];
						const BADGE_INACTIVE = ['border-white/15', 'text-white/70'];
						const ICON_ACTIVE = [
							['bg-[#FF7A1A]/15', 'text-[#FF7A1A]'],
							['bg-sky-500/15', 'text-sky-300'],
							['bg-fuchsia-500/15', 'text-fuchsia-300'],
							['bg-emerald-500/15', 'text-emerald-300']
						];
						const ICON_INACTIVE = ['bg-white/[0.05]', 'text-white/70'];
						const ARROW_ACTIVE = ['text-[#FF7A1A]/60', 'text-sky-400/60', 'text-fuchsia-400/60', 'text-emerald-400/60'];

						const DETAIL_ACTIVE = ['opacity-100', '-translate-y-0.5'];
						const DETAIL_INACTIVE = ['opacity-65', 'translate-y-0'];
						const DETAIL_ACCENT = [
							['border-[#FF7A1A]/45', 'shadow-[0_0_0_1px_rgba(255,122,26,0.16),0_0_26px_rgba(255,122,26,0.12)]'],
							['border-sky-500/35', 'shadow-[0_0_0_1px_rgba(56,189,248,0.14),0_0_26px_rgba(56,189,248,0.10)]'],
							['border-fuchsia-500/30', 'shadow-[0_0_0_1px_rgba(217,70,239,0.14),0_0_26px_rgba(217,70,239,0.10)]'],
							['border-emerald-500/30', 'shadow-[0_0_0_1px_rgba(16,185,129,0.14),0_0_26px_rgba(16,185,129,0.10)]']
						];
						const DOT_ACTIVE = ['bg-[#FF7A1A]', 'bg-sky-400', 'bg-fuchsia-400', 'bg-emerald-400'];

						const setActive = (idx) => {
							cards.forEach((card, i) => {
								const isActive = i === idx;
								card.classList.remove(...ACTIVE_CARD, ...INACTIVE_CARD, ...STEP_ACCENT.flat());
								card.classList.add(...(isActive ? ACTIVE_CARD : INACTIVE_CARD));
								if (isActive) card.classList.add(...STEP_ACCENT[i]);

								const badge = card.querySelector('[data-step-badge]');
								const icon = card.querySelector('[data-step-icon]');

								if (badge) {
									badge.classList.remove(...BADGE_INACTIVE, ...BADGE_ACTIVE.flat());
									badge.classList.add(...(isActive ? BADGE_ACTIVE[i] : BADGE_INACTIVE));
								}
								if (icon) {
									icon.classList.remove(...ICON_INACTIVE, ...ICON_ACTIVE.flat());
									icon.classList.add(...(isActive ? ICON_ACTIVE[i] : ICON_INACTIVE));
								}
							});

							if (detailCards.length >= 4) {
								detailCards.forEach((card, i) => {
									const isActive = i === idx;
									card.classList.remove(...DETAIL_ACTIVE, ...DETAIL_INACTIVE, ...DETAIL_ACCENT.flat());
									card.classList.add(...(isActive ? DETAIL_ACTIVE : DETAIL_INACTIVE));
									if (isActive) card.classList.add(...DETAIL_ACCENT[i]);
								});
							}

							if (dots.length === 4) {
								dots.forEach((dot, i) => {
									dot.classList.remove('scale-125', ...DOT_ACTIVE);
									dot.classList.add('bg-white/25');
									if (i === idx) {
										dot.classList.remove('bg-white/25');
										dot.classList.add('scale-125', DOT_ACTIVE[i]);
									}
								});
							}

								arrows.forEach((arrow) => {
								const n = Number(arrow.getAttribute('data-step-arrow'));
								const isActiveArrow = n === idx + 1;
									arrow.classList.remove(...ARROW_ACTIVE);
									if (isActiveArrow) arrow.classList.add(ARROW_ACTIVE[idx]);
								arrow.classList.toggle('opacity-90', isActiveArrow);
								arrow.classList.toggle('translate-x-0.5', isActiveArrow);
								arrow.classList.toggle('text-white/20', !isActiveArrow);
								arrow.classList.toggle('opacity-60', !isActiveArrow);
								arrow.classList.toggle('translate-x-0', !isActiveArrow);
							});
						};

						let index = 0;
						let timer = null;
						const start = () => {
							if (reduceMotion) return;
							if (timer) return;
							timer = window.setInterval(() => {
								index = (index + 1) % cards.length;
								setActive(index);
							}, 2500);
						};
						const stop = () => {
							if (!timer) return;
							window.clearInterval(timer);
							timer = null;
						};

						const pause = () => {
							root.classList.add('is-paused');
							stop();
						};
						const resume = () => {
							root.classList.remove('is-paused');
							start();
							setActive(index);
						};

						setActive(0);
						start();

						if (dots.length === 4) {
							dots.forEach((dot) => {
								dot.addEventListener('click', () => {
									const n = Number(dot.getAttribute('data-dot'));
									if (!Number.isFinite(n) || n < 1 || n > 4) return;
									index = n - 1;
									setActive(index);
									stop();
									start();
								});
							});
						}

						root.addEventListener('mouseenter', pause, { passive: true });
						root.addEventListener('mouseleave', resume, { passive: true });
						root.addEventListener('focusin', pause);
						root.addEventListener('focusout', resume);
					})();
				</script>


					</div>
				</div>

				<div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
					<div class="min-w-0">
						<h2 class="text-pretty text-2xl font-semibold tracking-tight md:text-3xl lg:text-4xl lg:leading-[1.12]">

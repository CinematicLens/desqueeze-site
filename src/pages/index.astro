								<span set:html={lucideSvg(Scan, 'h-6 w-6 md:h-7 md:w-7', 28)} aria-hidden="true" />
							</span>
							<span class="mx-1 h-6 w-px shrink-0 bg-white/20 sm:mx-1.5 md:h-7" aria-hidden="true"></span>
							<span class="inline-flex items-center justify-center px-3 sm:px-4 md:px-5" title="Monitor">
								<span set:html={lucideSvg(Activity, 'h-6 w-6 md:h-7 md:w-7', 28)} aria-hidden="true" />
							</span>
							<span class="mx-1 h-6 w-px shrink-0 bg-white/20 sm:mx-1.5 md:h-7" aria-hidden="true"></span>
							<span class="inline-flex items-center justify-center px-3 sm:px-4 md:px-5" title="Grade">
								<span set:html={lucideSvg(Palette, 'h-6 w-6 md:h-7 md:w-7', 28)} aria-hidden="true" />
							</span>
							<span class="mx-1 h-6 w-px shrink-0 bg-white/20 sm:mx-1.5 md:h-7" aria-hidden="true"></span>
							<span class="inline-flex items-center justify-center px-3 sm:px-4 md:px-5" title="Deliver">

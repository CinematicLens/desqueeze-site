							<div class="mt-1.5 h-0.5 w-12 rounded-full bg-[rgb(255,106,0)] sm:w-14" aria-hidden="true"></div>
						</div>

						<div
							class="suite-banner-icons flex shrink-0 items-center gap-0 border-l border-white/15 pl-5 text-white [color:rgba(255,255,255,0.92)] sm:pl-7 md:pl-9"

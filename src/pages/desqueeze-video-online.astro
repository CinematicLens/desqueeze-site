---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import GuidesNavigator from '../components/GuidesNavigator.astro';
import { downloadAppsButtonClass } from '../data/siteNav';
import { storeUrls } from '../data/storeUrls';
import { lucideSvg } from '../lib/lucideSvg';
import { ChevronRight, Zap, Download, Repeat, Smartphone, Cpu, Laptop } from 'lucide';

const pageTitle = 'Desqueeze Video Online | DeSqueeze Studio';
const pageDescription =
	'Desqueeze video online with Web Studio: upload a clip, pick a squeeze factor, and preview the corrected frame instantly before export.';
const pageKeywords = 'desqueeze video online, online desqueeze video, desqueeze footage online, anamorphic desqueeze online';

const startHereCardBase =
	'group flex min-h-[3.75rem] items-center gap-3 rounded-2xl border px-3.5 py-2.5 transition hover:border-white/25 hover:bg-white/[0.04] sm:min-h-[4rem] sm:gap-4 sm:px-4 sm:py-3 md:px-5';
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords}>
	<main class="min-h-dvh">
		<SiteHeader page="guides" />

		<section class="relative isolate overflow-hidden border-b border-white/10 bg-black">
			<div class="pointer-events-none absolute inset-0" aria-hidden="true">
				<div class="absolute inset-0 bg-[#060606]"></div>
				<div class="absolute inset-0 opacity-30 [background:radial-gradient(80%_60%_at_50%_10%,rgba(255,122,26,0.14),transparent_60%)]"></div>
			</div>

			<div class="page-shell relative z-10 py-14 md:py-20">
				<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] backdrop-blur-md md:p-8">
					<div
						class="pointer-events-none absolute left-1/2 top-16 h-[220px] w-[520px] -translate-x-1/2 rounded-full blur-3xl opacity-60 [background:radial-gradient(closest-side,rgba(255,122,26,0.18),transparent)]"
						aria-hidden="true"
					></div>

					<div class="relative grid gap-6 lg:grid-cols-[1.25fr_0.75fr] lg:items-start">
						<div class="min-w-0">
							<p class="text-xs font-semibold tracking-[0.22em] text-[#FF7A1A]">ANAMORPHIC GUIDE</p>
							<h1 class="mt-3 max-w-4xl text-balance text-3xl font-semibold tracking-tight text-white md:text-5xl">Desqueeze Video Online</h1>
							<p class="mt-4 max-w-3xl text-pretty text-base leading-relaxed text-white/70 md:text-lg">
								Upload squeezed footage, choose the correct squeeze factor, preview the corrected frame, then export for a clean cinematic delivery.
							</p>

							<div class="mt-7 flex flex-col gap-3 sm:flex-row sm:items-center">
								<a class={`${downloadAppsButtonClass} gap-2`} href="/products">
									Explore Apps
									<span set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
								</a>
								<a
									class="inline-flex items-center justify-center gap-2 self-start rounded-full border border-white/15 bg-white/[0.06] px-4 py-2 text-xs font-semibold text-white/90 hover:bg-white/[0.10] sm:self-auto"
									href="#workflow"
								>
									See workflow
									<span class="text-white/55" set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
								</a>
							</div>
						</div>

					</div>

					<GuidesNavigator variant="mobile" />
				</div>
			</div>
		</section>

		<section class="page-shell py-12 md:py-16">
			<div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
				<div class="min-w-0 space-y-12 md:space-y-14">
				<section id="workflow" class="scroll-mt-28">
					<div class="flex flex-col gap-2">
						<p class="text-xs font-semibold tracking-[0.22em] text-[#FF7A1A]">FILMMAKER WORKFLOW</p>
						<h2 class="text-xl font-semibold tracking-tight text-white md:text-2xl">Desqueeze video online from upload to final delivery.</h2>
					</div>

					<div class="mt-6 grid gap-3 md:grid-cols-[1fr_auto_1fr_auto_1fr_auto_1fr] md:items-stretch">
						<div class="rounded-3xl border border-[#FF7A1A]/20 bg-[#FF7A1A]/[0.06] p-5 shadow-[0_0_0_1px_rgba(255,122,26,0.12),0_0_26px_rgba(255,122,26,0.12)]">
							<div class="flex items-start justify-between gap-4">
								<div class="min-w-0">
									<p class="text-xs font-semibold tracking-[0.18em] text-white/60">SHOOT</p>
									<p class="mt-2 text-sm font-semibold text-white">Capture squeezed footage</p>
									<p class="mt-2 text-sm leading-relaxed text-white/65">Capture squeezed anamorphic footage on mobile or cinema camera.</p>
								</div>
								<span class="shrink-0 text-[#FF7A1A]" set:html={lucideSvg(Zap, 'h-5 w-5', 20)} aria-hidden="true"></span>
							</div>
						</div>

						<div class="hidden md:grid place-items-center px-1" aria-hidden="true">
							<span class="text-white/25" set:html={lucideSvg(ChevronRight, 'h-6 w-6', 24)}></span>
						</div>

						<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
							<div class="flex items-start justify-between gap-4">
								<div class="min-w-0">
									<p class="text-xs font-semibold tracking-[0.18em] text-white/55">PREVIEW</p>
									<p class="mt-2 text-sm font-semibold text-white">Check framing</p>
									<p class="mt-2 text-sm leading-relaxed text-white/60">Check framing and geometry before editing.</p>
								</div>
								<span class="shrink-0 text-white/35" set:html={lucideSvg(ChevronRight, 'h-5 w-5', 20)} aria-hidden="true"></span>
							</div>
						</div>

						<div class="hidden md:grid place-items-center px-1" aria-hidden="true">
							<span class="text-white/25" set:html={lucideSvg(ChevronRight, 'h-6 w-6', 24)}></span>
						</div>

						<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
							<div class="flex items-start justify-between gap-4">
								<div class="min-w-0">
									<p class="text-xs font-semibold tracking-[0.18em] text-white/55">DESQUEEZE</p>
									<p class="mt-2 text-sm font-semibold text-white">Correct the image</p>
									<p class="mt-2 text-sm leading-relaxed text-white/60">Choose the correct squeeze factor and correct the image.</p>
								</div>
								<span class="shrink-0 text-white/35" set:html={lucideSvg(Repeat, 'h-5 w-5', 20)} aria-hidden="true"></span>
							</div>
						</div>

						<div class="hidden md:grid place-items-center px-1" aria-hidden="true">
							<span class="text-white/25" set:html={lucideSvg(ChevronRight, 'h-6 w-6', 24)}></span>
						</div>

						<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
							<div class="flex items-start justify-between gap-4">
								<div class="min-w-0">
									<p class="text-xs font-semibold tracking-[0.18em] text-white/55">EXPORT</p>
									<p class="mt-2 text-sm font-semibold text-white">Deliver clean widescreen</p>
									<p class="mt-2 text-sm leading-relaxed text-white/60">Deliver corrected footage for edit, web, or client review.</p>
								</div>
								<span class="shrink-0 text-white/35" set:html={lucideSvg(Download, 'h-5 w-5', 20)} aria-hidden="true"></span>
							</div>
						</div>
					</div>
				</section>

				<section class="scroll-mt-28">
					<div class="flex flex-col gap-2">
						<p class="text-xs font-semibold tracking-[0.22em] text-[#FF7A1A]">WHAT DESQUEEZE DOES</p>
						<h2 class="text-xl font-semibold tracking-tight text-white md:text-2xl">Desqueeze video online: squeezed frame → corrected frame → cinematic output.</h2>
					</div>

					<div class="mt-6 grid gap-4 md:grid-cols-3">
						<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
							<p class="text-sm font-semibold text-white">Squeezed</p>
							<p class="mt-1 text-xs text-white/55">Tall / incorrect preview</p>
							<div class="mt-4 overflow-hidden rounded-2xl border border-white/15 bg-black/60">
								<div class="relative aspect-[16/10]">
									<div class="absolute inset-0 opacity-70 [background:radial-gradient(80%_60%_at_50%_20%,rgba(255,255,255,0.10),transparent_60%)]"></div>
									<div class="absolute inset-y-0 left-1/2 w-px -translate-x-1/2 bg-[#FF7A1A]/50"></div>
									<div class="absolute inset-y-0 left-[35%] w-px bg-white/10"></div>
									<div class="absolute inset-y-0 left-[65%] w-px bg-white/10"></div>
									<div class="absolute inset-x-0 top-[18%] h-px bg-white/10"></div>
									<div class="absolute inset-x-0 bottom-[18%] h-px bg-white/10"></div>
									<div class="absolute inset-0 [background:linear-gradient(90deg,rgba(255,255,255,0.02),transparent_26%,transparent_74%,rgba(255,255,255,0.02))]"></div>
								</div>
							</div>
						</div>

						<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
							<p class="text-sm font-semibold text-white">Desqueezed</p>
							<p class="mt-1 text-xs text-white/55">Corrected wide frame</p>
							<div class="mt-4 overflow-hidden rounded-2xl border border-white/15 bg-black/60">
								<div class="relative aspect-[16/10]">
									<div class="absolute inset-0 opacity-70 [background:radial-gradient(80%_60%_at_50%_20%,rgba(255,122,26,0.12),transparent_60%)]"></div>
									<div class="absolute inset-x-0 top-1/2 h-px -translate-y-1/2 bg-[#FF7A1A]/50"></div>
									<div class="absolute inset-x-0 top-[35%] h-px bg-white/10"></div>
									<div class="absolute inset-x-0 top-[65%] h-px bg-white/10"></div>
									<div class="absolute inset-y-0 left-[18%] w-px bg-white/10"></div>
									<div class="absolute inset-y-0 right-[18%] w-px bg-white/10"></div>
									<div class="absolute inset-0 [background:linear-gradient(to_bottom,rgba(255,255,255,0.03),transparent_30%,transparent_70%,rgba(255,255,255,0.03))]"></div>
								</div>
							</div>
						</div>

						<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
							<p class="text-sm font-semibold text-white">Final Output</p>
							<p class="mt-1 text-xs text-white/55">Letterbox delivery</p>
							<div class="mt-4 overflow-hidden rounded-2xl border border-white/15 bg-black/60">
								<div class="relative aspect-[16/10]">
									<div class="absolute inset-0 opacity-70 [background:radial-gradient(80%_60%_at_50%_20%,rgba(255,255,255,0.08),transparent_60%)]"></div>
									<div class="absolute inset-x-0 top-0 h-[22%] bg-black/80"></div>
									<div class="absolute inset-x-0 bottom-0 h-[22%] bg-black/80"></div>
									<div class="absolute inset-x-0 bottom-[22%] h-px bg-[#FF7A1A]/35"></div>
									<div class="absolute inset-0 [background:linear-gradient(to_bottom,transparent,rgba(0,0,0,0.20),transparent)]"></div>
								</div>
							</div>
						</div>
					</div>
				</section>

				<section id="web-studio" class="scroll-mt-28" aria-label="Web Studio tool">
						<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-6 md:p-7" data-desqueeze-studio>
							<div class="flex flex-col gap-1">
								<p class="text-xs font-semibold tracking-[0.22em] text-[#FF7A1A]">WEB STUDIO</p>
								<h2 class="mt-1 text-xl font-semibold tracking-tight text-white md:text-2xl">Desqueeze video online with a real-time preview</h2>
							</div>

							<div class="mt-4 flex flex-wrap items-center gap-2 text-xs font-semibold text-white/65">
								<span class="rounded-full border border-white/10 bg-black/40 px-3 py-1">Upload</span>
								<span class="text-white/25" aria-hidden="true">→</span>
								<span class="rounded-full border border-white/10 bg-black/40 px-3 py-1">Choose factor</span>
								<span class="text-white/25" aria-hidden="true">→</span>
								<span class="rounded-full border border-white/10 bg-black/40 px-3 py-1">Preview</span>
								<span class="text-white/25" aria-hidden="true">→</span>
								<span class="rounded-full border border-white/10 bg-black/40 px-3 py-1">Export</span>
							</div>

							<!-- Live Preview tool: keep exactly same as guides.astro -->
							<div class="mt-6 grid gap-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
								<div class="min-w-0 flex flex-col gap-4">
									<div class="relative overflow-hidden rounded-2xl border border-white/10 bg-black/40 shadow-[0_24px_70px_rgba(0,0,0,0.50)]">
										<div
											class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-200 ease-out [background:radial-gradient(60%_60%_at_50%_20%,rgba(255,122,26,0.22),transparent_58%)]"
											data-active-glow
											aria-hidden="true"
										></div>

										<div class="flex items-center justify-between gap-3 border-b border-white/10 px-5 py-4">
											<div class="min-w-0">
												<p class="inline-flex items-center gap-2 text-sm font-semibold text-white">
													<span class="relative inline-flex h-2.5 w-2.5">
														<span class="absolute inset-0 rounded-full bg-emerald-400/35 blur-[6px]" aria-hidden="true"></span>
														<span class="relative h-2.5 w-2.5 rounded-full bg-emerald-400 ring-1 ring-emerald-300/40" aria-hidden="true"></span>
													</span>
													Live Preview
												</p>
											</div>
										</div>

										<div class="p-5">
											<div
												class="group relative w-full overflow-hidden rounded-2xl border border-white/35 bg-black/60"
												style="aspect-ratio: var(--preview-aspect, 16 / 9);"
												data-preview-frame
											>
												<div class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-200 group-hover:opacity-100" aria-hidden="true">
													<div class="absolute inset-0 [background:linear-gradient(to_bottom,rgba(255,255,255,0.05),transparent_20%,transparent_80%,rgba(255,255,255,0.05))]"></div>
													<div class="absolute left-3 top-3 rounded-full border border-white/10 bg-black/50 px-2.5 py-1 text-[11px] font-semibold text-white/70">
														FPS <span data-fps-label>—</span>
													</div>
												</div>
												<div class="pointer-events-none absolute inset-0 opacity-0" data-fps-pulse aria-hidden="true"></div>

												<div class="absolute inset-0 overflow-hidden" data-preview-clip>
													<div
														class="absolute inset-0 min-h-0 origin-center will-change-transform"
														style="transform: scaleX(1); transform-origin: center; transition: transform 250ms ease;"
														data-preview
													>
														<video
															class="hidden block h-full w-full object-contain"
															playsinline
															muted
															loop
															autoplay
															preload="metadata"
															data-preview-video
														>
														</video>
														<img class="hidden block h-full w-full object-contain" alt="Preview" data-preview-image loading="lazy" decoding="async" />
														<div class="pointer-events-none absolute inset-0 grid place-items-center" data-preview-empty>
															<p class="rounded-full border border-white/15 bg-black/55 px-4 py-2 text-xs font-semibold tracking-[0.16em] text-white/70">
																UPLOAD IMAGE OR VIDEO TO PREVIEW
															</p>
														</div>
													</div>
												</div>

												<div class="pointer-events-none absolute inset-0 opacity-60 [background:radial-gradient(55%_55%_at_20%_18%,rgba(255,122,26,0.14),transparent_62%)]" aria-hidden="true"></div>
											</div>

											<div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
												<div class="flex flex-wrap items-center gap-2 invisible pointer-events-none" data-video-controls>
													<button
														type="button"
														class="inline-flex items-center justify-center gap-2 rounded-full border border-white/15 bg-white/[0.06] px-4 py-2 text-sm font-semibold text-white/90 hover:bg-white/[0.10] focus:outline-none focus:ring-2 focus:ring-white/30"
														data-play
													>
														Play
													</button>
													<button
														type="button"
														class="inline-flex items-center justify-center gap-2 rounded-full border border-white/15 bg-white/[0.06] px-4 py-2 text-sm font-semibold text-white/90 hover:bg-white/[0.10] focus:outline-none focus:ring-2 focus:ring-white/30"
														data-pause
													>
														Pause
													</button>
												</div>
											</div>
										</div>
									</div>

									<div class="flex flex-col rounded-2xl border border-white/10 bg-black/30 p-5" aria-label="Files">
										<div class="flex shrink-0 items-start justify-between gap-3">
											<div class="min-w-0">
												<p class="text-sm font-semibold text-white">Files</p>
												<p class="mt-1 text-xs text-white/60">Upload an image or video to preview.</p>
											</div>
											<div class="flex items-center gap-2">
												<button
													type="button"
													class="hidden rounded-full border border-white/15 bg-white/[0.06] px-4 py-2 text-sm font-semibold text-white/90 hover:bg-white/[0.10] focus:outline-none focus:ring-2 focus:ring-white/30"
													data-clear-files
												>
													Clear
												</button>
											</div>
										</div>

										<div
											class="mt-4 shrink-0 rounded-2xl border border-dashed border-white/15 bg-black/40 p-4 transition-colors hover:border-white/25 hover:bg-white/[0.04]"
											role="button"
											tabindex="0"
											data-dropzone
										>
											<input
												class="sr-only"
												type="file"
												accept=".jpg,.jpeg,.png,.webp,.mp4,.mov,.webm,video/mp4,video/webm,video/quicktime,image/jpeg,image/png,image/webp"
												multiple
												data-file-input
											/>
											<div class="flex items-start gap-3">
												<div class="mt-0.5 grid h-10 w-10 shrink-0 place-items-center rounded-2xl border border-white/10 bg-black/50 text-white/70" aria-hidden="true">
													<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
														<path d="M12 16V4" stroke-linecap="round"></path>
														<path d="M7 9l5-5 5 5" stroke-linecap="round" stroke-linejoin="round"></path>
														<path d="M4 20h16" stroke-linecap="round"></path>
													</svg>
												</div>
												<div class="min-w-0">
													<p class="text-sm font-semibold text-white">Drop files here or click to browse</p>
													<p class="mt-1 text-xs leading-relaxed text-white/60">Images or videos — keep one media type per batch</p>
												</div>
											</div>
										</div>

										<div class="mt-4 hidden shrink-0 rounded-2xl border border-amber-500/25 bg-amber-500/10 px-4 py-3 text-sm text-amber-100/90" data-mixed-error>
											Please upload either images or videos in one batch, not both.
										</div>

										<div class="file-list-scroll mt-4 min-h-0 max-h-[calc(2*3.5rem+0.5rem)] overflow-x-hidden overflow-y-auto pr-1">
											<div class="space-y-2" data-file-list>
												<p class="text-sm text-white/60">No files selected.</p>
											</div>
										</div>
									</div>
								</div>

								<div class="min-w-0 flex flex-col gap-4">
									<div class="rounded-2xl border border-white/10 bg-black/30 p-5">
										<p class="text-sm font-semibold text-white">Settings</p>

										<div class="mt-5 grid gap-4">
											<div class="rounded-2xl border border-white/10 bg-black/40 p-4">
												<p class="text-xs font-semibold tracking-[0.16em] text-white/60">Pre-defined Squeeze Factor</p>
												<label class="sr-only" for="squeeze-factor">Pre-defined Squeeze Factor</label>
												<select
													id="squeeze-factor"
													class="mt-2 h-11 w-full rounded-xl border border-white/15 bg-black/50 px-3 text-sm text-white/90 outline-none ring-0 focus:border-[#FF7A1A]/50 focus:ring-2 focus:ring-[#FF7A1A]/25"
													data-ratio
												>
													<option value="1">None (1.00×)</option>
													<option value="1.25">1.25×</option>
													<option value="1.30">1.30×</option>
													<option value="1.33">1.33× Classic</option>
													<option value="1.35">1.35×</option>
													<option value="1.42">1.42×</option>
													<option value="1.45">1.45×</option>
													<option value="1.50">1.50×</option>
													<option value="1.55">1.55×</option>
													<option value="1.60">1.60×</option>
													<option value="1.66">1.66×</option>
													<option value="1.75">1.75×</option>
													<option value="1.80">1.80×</option>
													<option value="2.00">2.00×</option>
													<option value="custom">Custom</option>
												</select>
												<div class="hidden" data-custom-ratio-row>
													<div class="mt-2 grid grid-cols-[1fr_auto] items-center gap-2">
														<input
															class="h-11 w-full rounded-xl border border-white/15 bg-black/50 px-3 text-sm text-white/90 outline-none focus:border-[#FF7A1A]/50 focus:ring-2 focus:ring-[#FF7A1A]/25"
															type="number"
															inputmode="decimal"
															step="0.01"
															min="1"
															max="3"
															value="1.33"
															aria-label="Custom ratio"
															data-custom-ratio
														/>
														<span class="text-xs font-semibold text-white/55">×</span>
													</div>

						<script is:inline>
							(() => {
								const root = document.querySelector('[data-desqueeze-studio]');
								if (!root) return;
								/* Script identical to guides.astro */
								const preview = root.querySelector('[data-preview]');
								const previewFrame = root.querySelector('[data-preview-frame]');
								const previewClip = root.querySelector('[data-preview-clip]');
								const previewVideo = root.querySelector('[data-preview-video]');
								const previewImage = root.querySelector('[data-preview-image]');
								const previewEmpty = root.querySelector('[data-preview-empty]');
								const activeGlow = root.querySelector('[data-active-glow]');
								const statusEl = root.querySelector('[data-status]');
								const fpsPulse = root.querySelector('[data-fps-pulse]');
								const fpsLabel = root.querySelector('[data-fps-label]');

								const conversionCard = root.querySelector('[data-conversion-card]');
								const correctedStatus = root.querySelector('[data-corrected-status]');
								const stickyCta = root.querySelector('[data-sticky-cta]');

								const ratioSelect = root.querySelector('[data-ratio]');
								const customRatioRow = root.querySelector('[data-custom-ratio-row]');
								const customRatioInput = root.querySelector('[data-custom-ratio]');
								const fpsSelect = root.querySelector('[data-fps]');
								const photoExport = root.querySelector('[data-photo-export]');
								const videoExport = root.querySelector('[data-video-export]');

								const fileInput = root.querySelector('[data-file-input]');
								const fileList = root.querySelector('[data-file-list]');
								const mixedError = root.querySelector('[data-mixed-error]');
								const dropzone = root.querySelector('[data-dropzone]');
								const clearBtn = root.querySelector('[data-clear-files]');

								const playBtn = root.querySelector('[data-play]');
								const pauseBtn = root.querySelector('[data-pause]');
								const videoControls = root.querySelector('[data-video-controls]');
								const previewModeRoot = root.querySelector('[data-preview-mode]');
								const previewModeFitBtn = root.querySelector('[data-preview-mode-btn="fit"]');
								const previewModeTrueBtn = root.querySelector('[data-preview-mode-btn="true"]');
								const exportSelectedBtn = root.querySelector('[data-export-selected]');
								const exportBatchBtn = root.querySelector('[data-export-batch]');

								const toast = root.querySelector('[data-toast]');
								const toastTitle = root.querySelector('[data-toast-title]');
								const toastBody = root.querySelector('[data-toast-body]');

								let currentObjectUrl = null;
								let selectedIndex = -1;
								let files = [];
								let mediaKind = null;
								let previewMode = 'fit';
								let fpsTimer = null;
								let toastTimer = null;

								const clamp = (v, min, max) => Math.min(max, Math.max(min, v));

								const formatRatio = (v) => {
									const n = Number(v);
									if (!Number.isFinite(n)) return null;
									const s = n.toFixed(2).replace(/\.00$/, '');
									return `${s}x`;
								};

								const getSelectedRatioLabel = () => {
									if (!ratioSelect) return null;
									if (ratioSelect.value === 'custom') return formatRatio(customRatioInput ? customRatioInput.value : '1.33');
									return formatRatio(ratioSelect.value);
								};

								const setConversionVisible = (on) => {
									if (conversionCard instanceof HTMLElement) {
										conversionCard.classList.toggle('opacity-0', !on);
										conversionCard.classList.toggle('translate-y-1', !on);
										conversionCard.classList.toggle('pointer-events-none', !on);
									}
									if (stickyCta instanceof HTMLElement) {
										stickyCta.classList.toggle('opacity-0', !on);
										stickyCta.classList.toggle('translate-y-1', !on);
										stickyCta.classList.toggle('pointer-events-none', !on);
									}
								};

								const updateCorrectedStatus = () => {
									const label = getSelectedRatioLabel();
									if (!correctedStatus) return;
									correctedStatus.textContent = label ? `✔ Corrected with ${label}` : '✔ Corrected with —';
								};

								const setStatus = (text) => {
									if (!statusEl) return;
									statusEl.textContent = text;
								};

								const showToast = (title, body) => {
									if (!toast) return;
									if (toastTitle) toastTitle.textContent = title;
									if (toastBody) toastBody.textContent = body;
									toast.style.opacity = '1';
									clearTimeout(toastTimer);
									toastTimer = setTimeout(() => {
										toast.style.opacity = '0';
									}, 1400);
								};

								const flashActive = () => {
									if (!activeGlow) return;
									activeGlow.style.opacity = '1';
									window.clearTimeout(activeGlow.__t);
									activeGlow.__t = window.setTimeout(() => {
										activeGlow.style.opacity = '0';
									}, 220);
								};

								const getRatio = () => {
									let ratio = 1;

									if (ratioSelect && ratioSelect.value === 'custom') {
										const v = customRatioInput ? Number(customRatioInput.value) : 1.33;
										ratio = clamp(Number.isFinite(v) ? v : 1.33, 1, 3);
									} else if (ratioSelect) {
										ratio = Number(ratioSelect.value) || 1;
									}

									return ratio;
								};

								const getActiveMediaEl = () => {
									if (previewImage && !previewImage.classList.contains('hidden')) return previewImage;
									if (previewVideo && !previewVideo.classList.contains('hidden')) return previewVideo;
									return null;
								};

								const getMediaAspect = (el) => {
									if (!el) return null;
									if (el instanceof HTMLImageElement) {
										const w = el.naturalWidth || 0;
										const h = el.naturalHeight || 0;
										if (w > 0 && h > 0) return w / h;
									}
									if (el instanceof HTMLVideoElement) {
										const w = el.videoWidth || 0;
										const h = el.videoHeight || 0;
										if (w > 0 && h > 0) return w / h;
									}
									return null;
								};

								const applyDesqueezePreview = () => {
									if (!previewFrame) return;
									const mediaEl = getActiveMediaEl();
									if (!mediaEl) return;

									const rect = previewFrame.getBoundingClientRect();
									if (rect.width <= 0 || rect.height <= 0) return;

									const containerAspect = rect.width / rect.height;
									const mediaAspect = getMediaAspect(mediaEl);
									const factor = getRatio();

									mediaEl.style.boxShadow = '0 0 0 1px rgba(255,255,255,0.35) inset';

									if (previewClip instanceof HTMLElement) {
										previewClip.style.overflowY = 'hidden';
										previewClip.style.overflowX = previewMode === 'true' ? 'auto' : 'hidden';
									}

									if (previewMode === 'true') {
										const pxW = Math.max(1, Math.round(rect.width * factor));
										const pxH = Math.max(1, Math.round(rect.height));
										if (preview instanceof HTMLElement) {
											preview.style.width = `${pxW}px`;
											preview.style.height = `${pxH}px`;
										}
										mediaEl.style.position = 'relative';
										mediaEl.style.left = '';
										mediaEl.style.top = '';
										mediaEl.style.transformOrigin = 'left center';
										mediaEl.style.width = `${(100 / factor).toFixed(4)}%`;
										mediaEl.style.height = '100%';
										mediaEl.style.transform = `scaleX(${factor})`;
										if (previewClip instanceof HTMLElement) {
											previewClip.scrollLeft = Math.max(0, (previewClip.scrollWidth - previewClip.clientWidth) / 2);
										}
										flashActive();
										return;
									}

									if (preview instanceof HTMLElement) {
										preview.style.width = '100%';
										preview.style.height = '100%';
									}
									mediaEl.style.position = 'absolute';
									mediaEl.style.left = '50%';
									mediaEl.style.top = '50%';
									mediaEl.style.width = '100%';
									mediaEl.style.height = '100%';
									mediaEl.style.transformOrigin = 'center center';

									if (!mediaAspect || !Number.isFinite(mediaAspect)) {
										mediaEl.style.transform = `translate(-50%, -50%) scaleX(${factor})`;
										return;
									}

									const desqueezedAspect = mediaAspect * factor;
									const fitScale = desqueezedAspect > containerAspect ? containerAspect / desqueezedAspect : 1;
									mediaEl.style.transform = `translate(-50%, -50%) scaleX(${factor}) scale(${fitScale})`;
									flashActive();
								};

								const setMixedError = (on) => {
									if (!mixedError) return;
									mixedError.classList.toggle('hidden', !on);
								};

								const setExportUi = (kind) => {
									mediaKind = kind;
									if (photoExport) photoExport.classList.toggle('hidden', kind !== 'image');
									if (videoExport) videoExport.classList.toggle('hidden', kind !== 'video');
									if (videoControls) {
										videoControls.classList.toggle('invisible', kind !== 'video');
										videoControls.classList.toggle('pointer-events-none', kind !== 'video');
									}
								};

								const setClearVisible = (on) => {
									if (!clearBtn) return;
									clearBtn.classList.toggle('hidden', !on);
								};

								const stopFpsPulse = () => {
									if (fpsTimer) window.clearInterval(fpsTimer);
									fpsTimer = null;
									if (fpsPulse) fpsPulse.style.opacity = '0';
								};

								const startFpsPulse = (fps) => {
									stopFpsPulse();
									if (!fpsPulse) return;

									const periodMs = Math.max(16, Math.round(1000 / fps));
									let on = false;
									fpsTimer = window.setInterval(() => {
										on = !on;
										fpsPulse.style.opacity = on ? '0.16' : '0';
										fpsPulse.style.background =
											'linear-gradient(to bottom, rgba(255,255,255,0.08), transparent 22%, transparent 78%, rgba(255,255,255,0.08))';
									}, periodMs);
								};

								const applyFps = () => {
									if (!fpsSelect) return;
									const v = fpsSelect.value;
									if (fpsLabel) fpsLabel.textContent = v === 'keep' ? 'orig' : v;

									if (v === 'keep') {
										stopFpsPulse();
									} else {
										const fps = clamp(Number(v) || 24, 10, 120);
										startFpsPulse(fps);
									}
									flashActive();
								};

								const extOf = (name) => {
									const s = String(name || '');
									const i = s.lastIndexOf('.');
									return i >= 0 ? s.slice(i + 1).toLowerCase() : '';
								};

								const classifyFile = (file) => {
									const t = String(file?.type || '');
									if (t.startsWith('image/')) return 'image';
									if (t.startsWith('video/')) return 'video';
									const ext = extOf(file?.name);
									if (['jpg', 'jpeg', 'png', 'webp'].includes(ext)) return 'image';
									if (['mp4', 'mov', 'webm'].includes(ext)) return 'video';
									return null;
								};

								const setPreviewFromFile = (file) => {
									if (!previewVideo || !previewImage) return;
									if (previewEmpty) previewEmpty.classList.add('hidden');

									if (currentObjectUrl) URL.revokeObjectURL(currentObjectUrl);
									currentObjectUrl = URL.createObjectURL(file);

									const kind = classifyFile(file);
									const isVideo = kind === 'video';
									const isImage = kind === 'image';

									if (isVideo) {
										previewImage.classList.add('hidden');
										previewVideo.classList.remove('hidden');
										previewVideo.src = currentObjectUrl;
										previewVideo.load();
									} else if (isImage) {
										previewVideo.pause();
										previewVideo.removeAttribute('src');
										previewVideo.load();
										previewVideo.classList.add('hidden');
										previewImage.classList.remove('hidden');
										previewImage.src = currentObjectUrl;
									}
								};

								const renderFileList = () => {
									if (!fileList) return;
									if (!files.length) {
										fileList.innerHTML = '<p class="text-sm text-white/60">No files selected.</p>';
										selectedIndex = -1;
										setClearVisible(false);
										return;
									}

									const rows = files
										.map((f, i) => {
											const active = i === selectedIndex;
											const name = String(f.name || 'Untitled');
											const meta = f.type ? `${f.type}` : 'file';
											return `
												<button
													type="button"
													class="group flex min-h-[3.5rem] w-full items-center justify-between gap-3 rounded-xl border px-4 py-3 text-left transition-colors ${
														active
															? 'border-[#FF7A1A]/35 bg-[#FF7A1A]/10'
															: 'border-white/10 bg-black/40 hover:bg-white/[0.06]'
													}"
													data-file-row="${i}"
												>
													<span class="min-w-0">
														<span class="block truncate text-sm font-semibold ${active ? 'text-[#FF7A1A]' : 'text-white/85'}">${name}</span>
														<span class="mt-0.5 block truncate text-xs ${active ? 'text-[#FF7A1A]/80' : 'text-white/55'}">${meta}</span>
													</span>
													<span class="shrink-0 rounded-full border border-white/10 bg-black/30 px-2.5 py-1 text-[11px] font-semibold text-white/60">
														${active ? 'Selected' : 'Select'}
													</span>
												</button>
											`;
										})
										.join('');

									fileList.innerHTML = `<div class="grid gap-2">${rows}</div>`;
									setClearVisible(true);
								};

								const ensureSelected = (index) => {
									selectedIndex = clamp(index, 0, files.length - 1);
									renderFileList();
									setPreviewFromFile(files[selectedIndex]);
									applyDesqueezePreview();
									applyFps();
								};

								ratioSelect?.addEventListener('change', () => {
									const isCustom = ratioSelect.value === 'custom';
									customRatioRow?.classList.toggle('hidden', !isCustom);
									applyDesqueezePreview();
									updateCorrectedStatus();
								});
								customRatioInput?.addEventListener(
									'input',
									() => {
										applyDesqueezePreview();
										updateCorrectedStatus();
									},
									{ passive: true }
								);

								fpsSelect?.addEventListener('change', applyFps);

								const setPickedFiles = (picked) => {
									setMixedError(false);
									const supported = picked.filter((f) => classifyFile(f));
									const kinds = new Set(supported.map((f) => classifyFile(f)).filter(Boolean));

									if (kinds.size > 1) {
										setMixedError(true);
										showToast('Mixed media', 'Please upload one media type per batch.');
										return;
									}

									const kind = kinds.size === 1 ? Array.from(kinds)[0] : null;
									files = supported;
									setExportUi(kind);
									renderFileList();
									if (files.length) ensureSelected(0);
									else showToast('No files', 'Please pick an image or video.');
									setConversionVisible(files.length > 0);
									updateCorrectedStatus();
								};

								fileInput?.addEventListener('change', () => {
									const picked = Array.from(fileInput.files || []);
									if (!picked.length) return;
									setPickedFiles(picked);
								});

								fileList?.addEventListener('click', (e) => {
									const btn = e.target && e.target.closest ? e.target.closest('[data-file-row]') : null;
									if (!btn) return;
									const idx = Number(btn.getAttribute('data-file-row'));
									if (!Number.isFinite(idx)) return;
									ensureSelected(idx);
								});

								const clearAll = () => {
									setMixedError(false);
									files = [];
									selectedIndex = -1;
									setExportUi(null);
									renderFileList();
									if (fileInput) fileInput.value = '';
									if (currentObjectUrl) {
										URL.revokeObjectURL(currentObjectUrl);
										currentObjectUrl = null;
									}
									if (previewImage) {
										previewImage.src = '';
										previewImage.classList.add('hidden');
									}
									if (previewVideo) {
										previewVideo.pause();
										previewVideo.removeAttribute('src');
										previewVideo.load();
										previewVideo.classList.add('hidden');
									}
									if (previewEmpty) previewEmpty.classList.remove('hidden');
									applyDesqueezePreview();
									applyFps();
									setConversionVisible(false);
									updateCorrectedStatus();
								};

								clearBtn?.addEventListener('click', clearAll);

								const openPicker = () => fileInput && fileInput.click();
								dropzone?.addEventListener('click', openPicker);
								dropzone?.addEventListener('keydown', (e) => {
									if (e.key === 'Enter' || e.key === ' ') {
										e.preventDefault();
										openPicker();
									}
								});
								['dragenter', 'dragover'].forEach((evt) => {
									dropzone?.addEventListener(evt, (e) => {
										e.preventDefault();
										dropzone.classList.add('border-[#FF7A1A]/40', 'bg-[#FF7A1A]/[0.06]');
									});
								});
								['dragleave', 'drop'].forEach((evt) => {
									dropzone?.addEventListener(evt, (e) => {
										e.preventDefault();
										dropzone.classList.remove('border-[#FF7A1A]/40', 'bg-[#FF7A1A]/[0.06]');
									});
								});
								dropzone?.addEventListener('drop', (e) => {
									const dt = e.dataTransfer;
									if (!dt?.files?.length) return;
									setPickedFiles(Array.from(dt.files));
								});

								playBtn?.addEventListener('click', () => {
									if (!previewVideo || previewVideo.classList.contains('hidden')) return;
									previewVideo.play().catch(() => {});
									flashActive();
								});

								pauseBtn?.addEventListener('click', () => {
									if (!previewVideo || previewVideo.classList.contains('hidden')) return;
									previewVideo.pause();
									flashActive();
								});

								const handleExportClick = (mode) => {
									setStatus('Processing');
									showToast('Coming soon', mode === 'batch' ? 'Batch export will be available soon.' : 'Export will be available soon.');
									window.setTimeout(() => setStatus('Idle'), 900);
								};

								exportSelectedBtn?.addEventListener('click', () => handleExportClick('selected'));
								exportBatchBtn?.addEventListener('click', () => handleExportClick('batch'));

								customRatioRow?.classList.add('hidden');
								setExportUi(null);
								setMixedError(false);
								setConversionVisible(false);
								updateCorrectedStatus();
								applyDesqueezePreview();
								applyFps();

								const setPreviewMode = (mode) => {
									previewMode = mode === 'true' ? 'true' : 'fit';
									if (previewModeFitBtn instanceof HTMLButtonElement) {
										const active = previewMode === 'fit';
										previewModeFitBtn.classList.toggle('border-[#FF7A1A]/35', active);
										previewModeFitBtn.classList.toggle('bg-[#FF7A1A]/10', active);
										previewModeFitBtn.classList.toggle('text-[#FF7A1A]', active);
										previewModeFitBtn.classList.toggle('shadow-[0_0_0_1px_rgba(255,122,26,0.16),0_0_18px_rgba(255,122,26,0.10)]', active);
										previewModeFitBtn.classList.toggle('border-white/10', !active);
										previewModeFitBtn.classList.toggle('bg-black/40', !active);
										previewModeFitBtn.classList.toggle('text-white/70', !active);
										previewModeFitBtn.classList.toggle('hover:bg-white/[0.06]', !active);
									}
									if (previewModeTrueBtn instanceof HTMLButtonElement) {
										const active = previewMode === 'true';
										previewModeTrueBtn.classList.toggle('border-[#FF7A1A]/35', active);
										previewModeTrueBtn.classList.toggle('bg-[#FF7A1A]/10', active);
										previewModeTrueBtn.classList.toggle('text-[#FF7A1A]', active);
										previewModeTrueBtn.classList.toggle('shadow-[0_0_0_1px_rgba(255,122,26,0.16),0_0_18px_rgba(255,122,26,0.10)]', active);
										previewModeTrueBtn.classList.toggle('border-white/10', !active);
										previewModeTrueBtn.classList.toggle('bg-black/40', !active);
										previewModeTrueBtn.classList.toggle('text-white/70', !active);
										previewModeTrueBtn.classList.toggle('hover:bg-white/[0.06]', !active);
									}
									applyDesqueezePreview();
								};

								if (previewModeRoot instanceof HTMLElement) {
									previewModeRoot.addEventListener('click', (e) => {
										const t = e.target;
										if (!(t instanceof Element)) return;
										const btn = t.closest('[data-preview-mode-btn]');
										if (!(btn instanceof HTMLElement)) return;
										const mode = btn.getAttribute('data-preview-mode-btn') || 'fit';
										setPreviewMode(mode);
									});
								}
								setPreviewMode('fit');

								previewImage?.addEventListener('load', applyDesqueezePreview, { passive: true });
								previewVideo?.addEventListener('loadedmetadata', applyDesqueezePreview, { passive: true });
								window.addEventListener('resize', applyDesqueezePreview, { passive: true });

								window.addEventListener(
									'beforeunload',
									() => {
										if (currentObjectUrl) URL.revokeObjectURL(currentObjectUrl);
									},
									{ once: true }
								);
							})();
						</script>
					</section>

				<section class="scroll-mt-28">
					<div class="flex flex-col gap-2">
						<p class="text-xs font-semibold tracking-[0.22em] text-[#FF7A1A]">CHOOSE THE RIGHT FACTOR</p>
						<h2 class="text-xl font-semibold tracking-tight text-white md:text-2xl">Choose the right squeeze factor to desqueeze video online.</h2>
					</div>

					<div class="mt-6 grid gap-3 md:grid-cols-2 xl:grid-cols-3">
						<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
							<p class="text-sm font-semibold text-white">1.25× / 1.30×</p>
							<p class="mt-2 text-sm text-white/65">Subtle mobile adapters and light squeeze looks.</p>
						</div>
						<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
							<p class="text-sm font-semibold text-white">1.33×</p>
							<p class="mt-2 text-sm text-white/65">Common mobile anamorphic lenses (fast, reliable framing).</p>
						</div>
						<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
							<p class="text-sm font-semibold text-white">1.50× / 1.55×</p>
							<p class="mt-2 text-sm text-white/65">Balanced cinematic look and wider corrected frame.</p>
						</div>
						<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
							<p class="text-sm font-semibold text-white">1.80×</p>
							<p class="mt-2 text-sm text-white/65">Wider stylized look — preview carefully before export.</p>
						</div>
						<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
							<p class="text-sm font-semibold text-white">2.00×</p>
							<p class="mt-2 text-sm text-white/65">Classic cinema anamorphic workflows and strong squeeze.</p>
						</div>
					</div>

					<div class="mt-4 rounded-3xl border border-white/10 bg-black/40 p-5 text-sm text-white/65">
						<p>
							<span class="font-semibold text-white">Quick check:</span> If faces look too wide, the factor is too high. If footage still looks tall,
							the factor is too low.
						</p>
					</div>
				</section>

				<section class="scroll-mt-28">
					<div class="flex flex-col gap-2">
						<p class="text-xs font-semibold tracking-[0.22em] text-[#FF7A1A]">COMMON MISTAKES</p>
						<h2 class="text-xl font-semibold tracking-tight text-white md:text-2xl">Desqueeze video online: common mistakes (and fast fixes).</h2>
					</div>

					<div class="mt-6 grid gap-3 md:grid-cols-2">
						<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
							<p class="text-sm font-semibold text-white">Cropping instead of desqueezing</p>
							<p class="mt-2 text-sm text-white/65">Crop hides the problem. Correct geometry first, then choose delivery framing.</p>
						</div>
						<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
							<p class="text-sm font-semibold text-white">Choosing the wrong factor</p>
							<p class="mt-2 text-sm text-white/65">Preview faces and circles — if they look off, adjust factor before export.</p>
						</div>
						<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
							<p class="text-sm font-semibold text-white">Exporting before previewing</p>
							<p class="mt-2 text-sm text-white/65">Always check framing + geometry in preview mode (Fit / True) first.</p>
						</div>
						<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
							<p class="text-sm font-semibold text-white">Forgetting final delivery ratio</p>
							<p class="mt-2 text-sm text-white/65">Decide whether you’re delivering 16:9, 2.39:1, or social crops after correction.</p>
						</div>
					</div>
				</section>

				<section class="scroll-mt-28">
					<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] md:p-8">
						<div class="flex flex-col gap-2">
							<p class="text-xs font-semibold tracking-[0.22em] text-[#FF7A1A]">CONTINUE YOUR WORKFLOW</p>
							<h2 class="text-2xl font-semibold tracking-tight text-white md:text-3xl">Desqueeze video online and continue your workflow</h2>
							<p class="mt-1 max-w-2xl text-sm leading-relaxed text-white/65 md:text-base">
								Run a quick preview in Web Studio, then move to native apps when you’re ready to shoot or batch export.
							</p>
						</div>

						<div class="mt-6 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
							<a class={`${downloadAppsButtonClass} gap-2`} href="/try-live">
								Try Web Studio
								<span set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
							</a>
							<a
								class="inline-flex items-center justify-center gap-2 rounded-full border border-white/15 bg-white/[0.06] px-5 py-2.5 text-sm font-semibold text-white/90 hover:bg-white/[0.10] focus:outline-none focus:ring-2 focus:ring-white/30"
								href="/products"
							>
								Explore Products
								<span class="text-white/55" set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
							</a>
							<a
								class="inline-flex items-center justify-center gap-2 rounded-full border border-white/15 bg-white/[0.06] px-5 py-2.5 text-sm font-semibold text-white/90 hover:bg-white/[0.10] focus:outline-none focus:ring-2 focus:ring-white/30"
								href="/products"
							>
								Continue in App
								<span class="text-white/55" set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
							</a>
						</div>
					</div>
				</section>
				</div>

				<aside class="hidden lg:block self-start justify-self-end lg:sticky lg:top-28 lg:border-l lg:border-white/10 lg:pl-6 lg:pr-1">
					<div class="max-h-[calc(100vh-8.25rem)] overflow-auto pr-1 [scrollbar-width:thin] [scrollbar-color:rgba(255,122,26,0.35)_rgba(255,255,255,0.06)]">
						<GuidesNavigator variant="desktop" />
					</div>
				</aside>
			</div>
		</section>

		<SiteFooter />
	</main>
</Layout>


---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import GuidesNavigator from '../components/GuidesNavigator.astro';
import { downloadAppsButtonClass } from '../data/siteNav';
import { storeUrls } from '../data/storeUrls';
import { lucideSvg } from '../lib/lucideSvg';
import { ChevronRight, Zap, Download, Repeat } from 'lucide';

const pageTitle = 'Filmmaking App Guides — CineLut Live Grade, FilmStudio, Anamorphic | DeSqueeze Studio';
const pageDescription =
	'Product guides for CineLut Live Grade, FilmStudio, Web Studio, Anamorphic Desqueezer, Windows and Android apps, plus how to de-squeeze 1.33×–2× footage for a clean cinematic frame.';

const startHereCardBase =
	'group flex min-h-[3.75rem] items-center gap-3 rounded-2xl border px-3.5 py-2.5 transition hover:border-white/25 hover:bg-white/[0.04] sm:min-h-[4rem] sm:gap-4 sm:px-4 sm:py-3 md:px-5';
---

<Layout title={pageTitle} description={pageDescription}>
	<main class="min-h-dvh">
		<SiteHeader page="guides" />

		<section class="relative isolate overflow-hidden border-b border-white/10 bg-black">
			<div class="pointer-events-none absolute inset-0" aria-hidden="true">
				<div class="absolute inset-0 bg-[#060606]"></div>
				<div class="absolute inset-0 opacity-30 [background:radial-gradient(80%_60%_at_50%_10%,var(--color-accent-14),transparent_60%)]"></div>
			</div>

			<div class="page-shell relative z-10 py-14 md:py-20">
				<div class="rounded-3xl border border-white/10 bg-white/[0.03] p-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] backdrop-blur-md md:p-8">
					<div
						class="pointer-events-none absolute left-1/2 top-16 h-[220px] w-[520px] -translate-x-1/2 rounded-full blur-3xl opacity-60 [background:radial-gradient(closest-side,var(--color-accent-18),transparent)]"
						aria-hidden="true"
					></div>

					<div class="relative grid gap-6 lg:grid-cols-[1.25fr_0.75fr] lg:items-start">
						<div class="min-w-0">
							<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">PRODUCT GUIDES</p>
							<h1 class="mt-3 max-w-4xl text-balance text-3xl font-semibold tracking-tight text-white md:text-5xl">
								Guides for every filmmaking tool in the suite
							</h1>
							<p class="mt-4 max-w-3xl text-pretty text-base leading-relaxed text-white/70 md:text-lg">
								Explore <strong class="font-semibold text-white/90">Anamorphic Desqueezer</strong> on iPhone, iPad, and MacBook, then <strong class="font-semibold text-white/90">CineLut Live Grade</strong> and <strong class="font-semibold text-white/90">FilmStudio</strong> for live grade and capture. Jump to Windows and Android for batch or cart workflows. The geometry deep dive covers 1.33× through 2× — preview, correct, and export for a clean cinematic frame.
							</p>

							<div class="mt-7 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
								<a class={`${downloadAppsButtonClass} gap-2`} href="/#ecosystem">
									Explore Apps
									<span set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
								</a>
								<a
									class="inline-flex items-center justify-center gap-2 self-start rounded-full border border-white/15 bg-white/[0.06] px-4 py-2 text-xs font-semibold text-white/90 hover:bg-white/[0.10] sm:self-auto"
									href="#guide-anamorphic"
								>
									Anamorphic (iPhone · Mac)
									<span class="text-white/55" set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
								</a>
								<a
									class="inline-flex items-center justify-center gap-2 self-start rounded-full border border-white/15 bg-white/[0.06] px-4 py-2 text-xs font-semibold text-white/90 hover:bg-white/[0.10] sm:self-auto"
									href="#guide-cinelut-live-grade"
								>
									CineLut guide
									<span class="text-white/55" set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
								</a>
								<a
									class="inline-flex items-center justify-center gap-2 self-start rounded-full border border-white/15 bg-white/[0.06] px-4 py-2 text-xs font-semibold text-white/90 hover:bg-white/[0.10] sm:self-auto"
									href="#guide-filmstudio"
								>
									FilmStudio guide
									<span class="text-white/55" set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
								</a>
								<a
									class="inline-flex items-center justify-center gap-2 self-start rounded-full border border-white/15 bg-white/[0.06] px-4 py-2 text-xs font-semibold text-white/90 hover:bg-white/[0.10] sm:self-auto"
									href="#guide-anamorphic-detailed"
								>
									Geometry deep dive
									<span class="text-white/55" set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
								</a>
							</div>
						</div>
					</div>

					<GuidesNavigator variant="mobile" />
				</div>
			</div>
		</section>

		<section class="page-shell py-12 md:py-16">
			<div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
				<div class="min-w-0 space-y-12 md:space-y-14">
				<section id="guide-anamorphic" class="scroll-mt-28">
					<div class="flex flex-col gap-2">
						<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">ANAMORPHIC DESQUEEZER · IPHONE · IPAD · MAC</p>
						<h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)] md:text-2xl">Anamorphic Desqueezer — batch geometry on Apple devices</h2>
						<p class="mt-2 max-w-3xl text-sm leading-relaxed text-[var(--color-muted)] md:text-base">
							Use <strong class="font-semibold text-[var(--color-text)]">Anamorphic Desqueezer</strong> on iPhone, iPad, or MacBook when you need a native flagship pipeline: import squeezed clips from FilmStudio or cinema cameras, dial <strong class="font-semibold text-[var(--color-text)]">1.25× through 2×</strong> squeeze, preview in real time, and export clean widescreen masters without round-tripping through a full NLE for every pass.
						</p>
						<p class="mt-3 max-w-3xl text-sm leading-relaxed text-[var(--color-muted)] md:text-base">
							<strong class="font-semibold text-[var(--color-text)]">iPhone / iPad on set:</strong> queue dailies on the cart, sanity-check lens orientation, and hand off ProRes or HEVC that already matches the village monitor. <strong class="font-semibold text-[var(--color-text)]">MacBook:</strong> same ratios and batch muscle for location pulls when you want keyboard shortcuts and larger scopes before you commit to Resolve or Avid. No app installed yet?{' '}
							<a class="font-semibold text-[var(--color-accent)] underline decoration-[var(--color-accent-border)] underline-offset-2" href="/try-live">Preview in Web Studio ↗</a>.
						</p>
						<p class="mt-3 max-w-3xl text-sm leading-relaxed text-[var(--color-muted)] md:text-base">
							For the long-form walkthrough (shoot → export, factors, mistakes), jump to{' '}
							<a class="font-semibold text-[var(--color-accent)] underline decoration-[var(--color-accent-border)] underline-offset-2" href="#guide-anamorphic-detailed">Anamorphic geometry — detailed ↓</a>.
						</p>
						<div class="mt-5 flex flex-wrap gap-3">
							<a
								class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface-strong)] px-4 py-2 text-sm font-semibold text-[var(--color-text)] hover:bg-[var(--color-surface)]"
								href={storeUrls.anamorphicApple}
								target="_blank"
								rel="noopener noreferrer"
							>
								App Store — Anamorphic Desqueezer
								<span class="text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
							</a>
							<a
								class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface-strong)] px-4 py-2 text-sm font-semibold text-[var(--color-text)] hover:bg-[var(--color-surface)]"
								href="/products#anamorphic"
							>
								Product overview
								<span class="text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
							</a>
							<a
								class="inline-flex items-center gap-2 rounded-full border border-[var(--color-accent-border)] bg-[var(--color-accent-soft)] px-4 py-2 text-sm font-semibold text-[var(--color-accent)] hover:bg-[var(--color-accent-15)]"
								href="/try-live"
							>
								Web Studio
								<span class="text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
							</a>
						</div>
					</div>
				</section>

				<section id="guide-cinelut-live-grade" class="scroll-mt-28">
					<div class="flex flex-col gap-2">
						<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">CINELUT LIVE GRADE · MAC</p>
						<h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)] md:text-2xl">CineLut Live Grade — live LUT &amp; CDL on set</h2>
						<p class="mt-2 max-w-3xl text-sm leading-relaxed text-[var(--color-muted)] md:text-base">
							Use CineLut Live Grade when you want a <strong class="font-semibold text-[var(--color-text)]">camera feed over SDI or HDMI</strong> on a MacBook, with LUTs, ASC-CDL-style primaries, and scopes updating in real time while you record graded <strong class="font-semibold text-[var(--color-text)]">ProRes</strong> to disk—so dailies match what the DP signed off on.
						</p>
						<p class="mt-3 max-w-3xl text-sm leading-relaxed text-[var(--color-muted)] md:text-base">
							<strong class="font-semibold text-[var(--color-text)]">Typical flow:</strong> connect a supported capture device → choose your input format and monitoring (waveform, parade, vectorscope) → load a show LUT and trim CDL until the look locks → record takes with timecode / burn-in options if you need them → export CDL, LUT, AMF, or EDL+CDL packages so Silverstack, DaVinci Resolve, or editorial can inherit the same grade without round-tripping guesses.
						</p>
						<p class="mt-3 max-w-3xl text-sm leading-relaxed text-[var(--color-muted)] md:text-base">
							<strong class="font-semibold text-[var(--color-text)]">Why it saves money:</strong> you can lean on fast Mac storage and CPUs instead of expensive in-camera media for every roll, while still keeping a disciplined on-set signal path.
						</p>
						<div class="mt-5 flex flex-wrap gap-3">
							<a
								class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface-strong)] px-4 py-2 text-sm font-semibold text-[var(--color-text)] hover:bg-[var(--color-surface)]"
								href={storeUrls.cineLutMac}
								target="_blank"
								rel="noopener noreferrer"
							>
								Mac App Store — CineLut Live Grade
								<span class="text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
							</a>
							<a
								class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface-strong)] px-4 py-2 text-sm font-semibold text-[var(--color-text)] hover:bg-[var(--color-surface)]"
								href="/products#cinelut"
							>
								Product overview
								<span class="text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
							</a>
						</div>
					</div>
				</section>

				<section id="guide-filmstudio" class="scroll-mt-28">
					<div class="flex flex-col gap-2">
						<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">FILMSTUDIO · IPHONE · IPAD · MAC</p>
						<h2 class="text-xl font-semibold tracking-tight text-[var(--color-text)] md:text-2xl">FilmStudio — field-ready cinema camera on Apple devices</h2>
						<p class="mt-2 max-w-3xl text-sm leading-relaxed text-[var(--color-muted)] md:text-base">
							FilmStudio is for <strong class="font-semibold text-[var(--color-text)]">capture discipline</strong>: manual ISO, shutter, focus, and white balance; zebras, peaking, histogram and waveform; timecode and take naming; and export paths that match how video village labels reels. It pairs naturally with anamorphic rigs when you need honest framing before you de-squeeze in post.
						</p>
						<p class="mt-3 max-w-3xl text-sm leading-relaxed text-[var(--color-muted)] md:text-base">
							<strong class="font-semibold text-[var(--color-text)]">On-set habit:</strong> build presets per lens serial, lock AE/AF when the block is stable, and tag takes while the slate is fresh so editorial and Anamorphic Desqueezer metadata stay aligned. On Mac (Apple Silicon), use the same App Store listing where Apple surfaces the Mac build.
						</p>
						<p class="mt-3 max-w-3xl text-sm leading-relaxed text-[var(--color-muted)] md:text-base">
							<strong class="font-semibold text-[var(--color-text)]">After the shoot:</strong> move squeezed clips into Anamorphic Desqueezer or the Web Studio for ratio correction, or into CineLut Live Grade if you are live-grading from a camera feed on Mac.
						</p>
						<div class="mt-5 flex flex-wrap gap-3">
							<a
								class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface-strong)] px-4 py-2 text-sm font-semibold text-[var(--color-text)] hover:bg-[var(--color-surface)]"
								href={storeUrls.filmStudioIos}
								target="_blank"
								rel="noopener noreferrer"
							>
								App Store — FilmStudio
								<span class="text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
							</a>
							<a
								class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface-strong)] px-4 py-2 text-sm font-semibold text-[var(--color-text)] hover:bg-[var(--color-surface)]"
								href="/products#filmstudio"
							>
								Product overview
								<span class="text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
							</a>
						</div>
					</div>
				</section>

				<section id="guide-windows" class="scroll-mt-28">
					<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-[inset_0_1px_0_var(--color-border)] md:p-7">
						<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">WINDOWS</p>
						<h2 class="mt-2 text-lg font-semibold tracking-tight text-[var(--color-text)] md:text-xl">PC dailies — live anamorphic, grading, and post desqueeze</h2>
						<p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)] md:text-base">
							<strong class="font-semibold text-[var(--color-text)]">AnamorphicDesqueezePro</strong> on the Microsoft Store covers the full Windows pipeline—from <strong class="font-semibold text-[var(--color-text)]">live anamorphic</strong> preview and <strong class="font-semibold text-[var(--color-text)]">live grading</strong> on set through <strong class="font-semibold text-[var(--color-text)]">post desqueeze</strong> when you are ready to deliver.
						</p>
						<ul class="mt-4 list-disc space-y-2 pl-5 text-sm text-[var(--color-muted)] md:text-base">
							<li><strong class="font-semibold text-[var(--color-text)]">Live anamorphic, live grading, and post desqueeze</strong></li>
							<li>Folder-based batch processing</li>
							<li>CinemaScope presets from 2.39:1 through 2.76:1</li>
							<li>3D LUT + CDL grading for batch and monitoring</li>
							<li>EDL + CDL export packages for Resolve and editorial conform</li>
							<li>Local processing for longer clips and higher bitrates</li>
						</ul>
						<p class="mt-4 text-sm leading-relaxed text-[var(--color-muted)] md:text-base">
							Use CDL trims to lock a show LUT across a reel, then lean on <strong class="font-semibold text-[var(--color-text)]">EDL</strong> when editorial needs shot lists, handles, and reconform metadata alongside the corrected masters—the same handoff philosophy as CineLut Live Grade on Mac, tuned for Windows batch pipelines. Confirm squeeze and framing in the browser first with{' '}
							<a class="font-semibold text-[var(--color-accent)] underline decoration-[var(--color-accent-border)] underline-offset-2" href="/try-live">Web Studio ↗</a>.
						</p>
						<div class="mt-4 flex flex-wrap gap-3">
							<a
								class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface-strong)] px-4 py-2 text-sm font-semibold text-[var(--color-text)] hover:bg-[var(--color-surface)]"
								href={storeUrls.windowsPro}
								target="_blank"
								rel="noopener noreferrer"
							>
								Microsoft Store — AnamorphicDesqueezePro
								<span class="text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
							</a>
							<a
								class="inline-flex items-center gap-2 rounded-full border border-[var(--color-accent-border)] bg-[var(--color-accent-soft)] px-4 py-2 text-sm font-semibold text-[var(--color-accent)] hover:bg-[var(--color-accent-15)]"
								href="/try-live"
							>
								Web Studio
								<span class="text-[var(--color-muted-faint)]" set:html={lucideSvg(ChevronRight, 'h-4 w-4', 16)} aria-hidden="true"></span>
							</a>
						</div>
						<p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)] md:text-base">
							<strong class="font-semibold text-[var(--color-text)]">Check in app:</strong> Store builds move often—open AnamorphicDesqueezePro and review the Microsoft Store listing and in-app export / grade panels for the exact <strong class="font-semibold text-[var(--color-text)]">EDL, CDL, and LUT</strong> options in your installed version before you freeze a deliverables memo.
						</p>
						<p class="mt-4 text-sm leading-relaxed text-[var(--color-muted)] md:text-base">
							<strong class="font-semibold text-[var(--color-text)]">DocRev Manager (Windows)</strong> — manage your film documents in one system: <strong class="font-semibold text-[var(--color-text)]">PDF</strong>, <strong class="font-semibold text-[var(--color-text)]">Word</strong>, call sheets, delivery memos, and revision notes without losing versions across the production.
						</p>
						<ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-[var(--color-muted)] md:text-base">
							<li>PDF and Word production files in a searchable project library</li>
							<li>Versioned records for call sheets, notes, and delivery paperwork</li>
							<li>Fast lookup on set and in post when producers ask for the latest doc</li>
						</ul>
						<p class="mt-4 text-sm leading-relaxed text-[var(--color-muted)] md:text-base">
							Add <strong class="font-semibold text-[var(--color-text)]">CineSnap AI (Windows)</strong> when you need <strong class="font-semibold text-[var(--color-text)]">individual photo editing</strong>—full-frame looks, crops, and compare—then <strong class="font-semibold text-[var(--color-text)]">export in batch</strong> across a folder or gallery so weddings, stills pulls, and social crops ship with the same grade.
						</p>
						<div class="mt-4 flex flex-wrap gap-2">
							<a class="text-sm font-semibold text-[var(--color-accent)] underline decoration-[var(--color-accent-border)] underline-offset-2 hover:brightness-110" href="/try-live">Web Studio ↗</a>
							<span class="text-[var(--color-muted-faint)]">·</span>
							<a class="text-sm font-semibold text-[var(--color-accent)] underline decoration-[var(--color-accent-border)] underline-offset-2 hover:brightness-110" href={storeUrls.cineSnapAiWindows} target="_blank" rel="noopener noreferrer">CineSnap AI (Windows) ↗</a>
							<span class="text-[var(--color-muted-faint)]">·</span>
							<a class="text-sm font-semibold text-[var(--color-accent)] underline decoration-[var(--color-accent-border)] underline-offset-2 hover:brightness-110" href={storeUrls.docRevWindows} target="_blank" rel="noopener noreferrer">DocRev Manager ↗</a>
						</div>
					</div>
				</section>

				<section id="guide-android" class="scroll-mt-28">
					<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-[inset_0_1px_0_var(--color-border)] md:p-7">
						<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">ANDROID</p>
						<h2 class="mt-2 text-lg font-semibold tracking-tight text-[var(--color-text)] md:text-xl">Batch geometry on the go, or live desqueeze on set</h2>
						<p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)] md:text-base">
							<strong class="font-semibold text-[var(--color-text)]">Anamorphic Desqueezer</strong> on Google Play is the batch + LUT + LiveGrade-style monitoring path when you need true CinemaScope exports up to 4K without opening a full NLE on the cart.
						</p>
						<p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)] md:text-base">
							<strong class="font-semibold text-[var(--color-text)]">Anamorphic Desqueeze Pro Cam</strong> is the live monitor + Post Studio + recording lane when you want corrected stills and clips landing in DCIM without a desktop round-trip.
						</p>
						<div class="mt-4 flex flex-wrap gap-2">
							<a class="text-sm font-semibold text-[var(--color-accent)] underline decoration-[var(--color-accent-border)] underline-offset-2 hover:brightness-110" href={storeUrls.androidDesqueeze} target="_blank" rel="noopener noreferrer">Anamorphic Desqueezer ↗</a>
							<span class="text-[var(--color-muted-faint)]">·</span>
							<a class="text-sm font-semibold text-[var(--color-accent)] underline decoration-[var(--color-accent-border)] underline-offset-2 hover:brightness-110" href={storeUrls.androidProCam} target="_blank" rel="noopener noreferrer">Pro Cam ↗</a>
						</div>
					</div>
				</section>

				<section id="guide-more-mac" class="scroll-mt-28">
					<div class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface-strong)] p-6 shadow-[inset_0_1px_0_var(--color-border)] md:p-7">
						<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-accent)]">MORE MAC &amp; IOS</p>
						<h2 class="mt-2 text-lg font-semibold tracking-tight text-[var(--color-text)] md:text-xl">MediaUtility, DMS, and CineSnap AI</h2>
						<ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-[var(--color-muted)] md:text-base">
							<li>
								<strong class="font-semibold text-[var(--color-text)]">MediaUtility</strong> — compress, resize, and convert stills and video on iPhone, iPad, and Mac.
								<a class="ml-1 font-semibold text-[var(--color-accent)] underline decoration-[var(--color-accent-border)] underline-offset-2" href={storeUrls.mediaUtilityIos} target="_blank" rel="noopener noreferrer">App Store ↗</a>
							</li>
							<li>

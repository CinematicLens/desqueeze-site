---
import { storeUrls } from '../data/storeUrls';
import { PRODUCTS_PAGE_DESCRIPTION, PRODUCTS_PAGE_TITLE } from '../data/siteMeta';
import { loadFilmStudioScreenshots } from '../lib/filmStudioScreenshots';
import { fetchAppStoreMeta } from '../lib/storeMeta';
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SuiteProductAccordion from '../components/SuiteProductAccordion.astro';
import SiteFooter from '../components/SiteFooter.astro';

const filmStudioMeta = await fetchAppStoreMeta('6761248370');
const anamorphicMeta = await fetchAppStoreMeta('6757354068');
const cineLutMeta = await fetchAppStoreMeta('6760215504');

const filmStudioScreenshots = loadFilmStudioScreenshots();
---

<Layout title={PRODUCTS_PAGE_TITLE} description={PRODUCTS_PAGE_DESCRIPTION}>
	<main class="min-h-dvh">
		<SiteHeader page="products" />

		<section class="page-shell py-14 md:py-20">
			<p class="text-xs font-medium tracking-[0.18em] text-white/60">DEEP DIVES</p>
			<h1 class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl">Products</h1>
			<p class="mt-3 max-w-2xl text-white/70">
				Demos, specs, and workflow notes for FilmStudio, Anamorphic Desqueezer, and CineLut Live Grade.
			</p>
			<SuiteProductAccordion
				filmStudioMeta={filmStudioMeta}
				anamorphicMeta={anamorphicMeta}
				cineLutMeta={cineLutMeta}
				storeUrls={storeUrls}
				filmStudioScreenshots={filmStudioScreenshots}
			/>

			<section id="export" class="mt-10 rounded-2xl border border-white/10 bg-white/[0.03] p-6 md:p-7">
				<p class="text-xs font-medium tracking-[0.18em] text-white/60">EXPORT</p>
				<h2 class="mt-2 text-xl font-semibold tracking-tight text-white md:text-2xl">MediaUtility</h2>
				<p class="mt-2 max-w-2xl text-sm text-white/70 md:text-base">
					Compress, convert, and prepare delivery files fast — clean output for real workflows.
				</p>
				<a
					class="mt-4 inline-flex items-center gap-2 rounded-full border border-white/12 bg-black/40 px-4 py-2 text-xs font-semibold text-white/85 hover:bg-white/[0.06]"
					href={storeUrls.mediaUtilityHub}
					target="_blank"
					rel="noopener noreferrer"
				>
					Open MediaUtility hub
					<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
						<path d="M7 17L17 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
						<path d="M10 7h7v7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</a>
			</section>
		</section>

		<SiteFooter />
	</main>

</Layout>

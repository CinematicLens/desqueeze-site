	{ key: 'apple', label: 'Apple' },
	{ key: 'android', label: 'Android' },
	{ key: 'windows', label: 'Windows' },
];

const productsPlatformTabsInit = `(() => {
  const DEFAULT = 'apple';
  const tabs = Array.from(document.querySelectorAll('[data-platform-tab]'));
  const sections = Array.from(document.querySelectorAll('[data-platform-section]'));

  const setActive = (key) => {
    tabs.forEach((t) => {
      const k = t.getAttribute('data-platform-tab') || DEFAULT;
      const active = k === key;
      t.classList.toggle('border-[#FF7A1A]/35', active);
      t.classList.toggle('bg-[#FF7A1A]/10', active);
      t.classList.toggle('text-[#FF7A1A]', active);
      t.classList.toggle('border-white/10', !active);
      t.classList.toggle('bg-black/40', !active);
      t.classList.toggle('text-white/65', !active);
    });

    sections.forEach((s) => {
      const k = s.getAttribute('data-platform-section') || '';
      const on =
        (key === 'apple' && (k === 'ios' || k === 'mac')) ||
        (key === 'android' && k === 'android') ||
        (key === 'windows' && k === 'windows');
      s.classList.toggle('hidden', !on);
    });
  };

  tabs.forEach((t) => {
    t.addEventListener('click', () => setActive(t.getAttribute('data-platform-tab') || DEFAULT));
  });

  setActive(DEFAULT);
})();`;

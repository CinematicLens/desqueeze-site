										{a.features.map((f) => (
											<li class="flex gap-2">
												<span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[#FF7A1A]/70" aria-hidden="true"></span>
												<span class="min-w-0">{f}</span>
											</li>
										))}
									</ul>

								</article>
							))}
					</div>
				</section>

				<!-- Web -->
				<section data-platform-section="web" class="hidden">
					<div class="flex flex-col gap-2">
						<p class="text-xs font-semibold tracking-[0.22em] text-[#FF7A1A]">WEB STUDIO</p>
						<p class="text-sm text-white/70">Quick browser-based previews and light batch processing.</p>
					</div>
					<div class="mt-6 grid gap-4 lg:grid-cols-2">
						{apps
							.filter((a) => a.platforms.includes('web'))
							.map((a) => (
								<article class="rounded-3xl border border-white/10 bg-white/[0.03] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]" data-app-card data-platforms={a.platforms.join(',')}>
									<div class="grid grid-cols-[minmax(0,1fr)_auto] items-start gap-3 sm:gap-4">
										<div class="flex min-w-0 items-start gap-4">
											<span class="grid h-12 w-12 shrink-0 place-items-center overflow-hidden rounded-2xl border border-white/10 bg-black/50">
												<span class="text-xs font-semibold text-white/70">WS</span>
											</span>
											<div class="min-w-0">
												<p class="text-sm font-semibold text-white">{a.name}</p>
												<p class="mt-1 text-sm text-white/65">{a.positioning}</p>
												<p class="mt-2 text-xs font-semibold tracking-[0.16em] text-white/45">{a.role}</p>
											</div>
										</div>

										<ProductStorePill variant="web" href={a.ctaHref} accessibilityLabel={a.ctaLabel} />
									</div>

									<ul class="mt-4 grid gap-2 text-sm text-white/70">
										{a.features.map((f) => (
											<li class="flex gap-2">
												<span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[#FF7A1A]/70" aria-hidden="true"></span>
												<span class="min-w-0">{f}</span>
											</li>
										))}
									</ul>

								</article>
							))}
					</div>
				</section>
			</div>
		</section>

		<SiteFooter />
	</main>

	<script is:inline set:html={productsPlatformTabsInit}></script>
</Layout>

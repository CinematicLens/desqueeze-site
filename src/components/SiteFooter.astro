---
---

<div class="page-shell pb-10 pt-12 md:pb-14 md:pt-16">
	<footer
		class="relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-b from-white/[0.045] via-black/50 to-black/70 shadow-[inset_0_1px_0_rgba(255,255,255,0.05)] backdrop-blur-md"
		aria-label="Site footer"
	>
		<div
			class="pointer-events-none absolute inset-x-4 top-0 mx-auto h-px max-w-[min(56rem,92%)] rounded-full bg-gradient-to-r from-transparent via-[#FF7A1A]/35 to-transparent blur-[0.5px] sm:inset-x-8"
			aria-hidden="true"
		></div>
		<div class="relative px-6 py-9 md:px-10 md:py-10">
			<div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-5 lg:gap-x-8 lg:gap-y-8">
				<div class="sm:col-span-2 lg:col-span-1">
					<div class="flex items-start gap-3">
						<span
							class="grid h-10 w-10 shrink-0 place-items-center rounded-lg border border-[#FF7A1A]/35 bg-[#FF7A1A]/[0.08] text-[11px] font-bold tracking-tight text-[#FF7A1A]"
							aria-hidden="true"
						>
							DS
						</span>
						<div class="min-w-0">
							<p class="text-sm font-semibold tracking-tight text-white">DeSqueeze Studio</p>
							<p class="mt-2 max-w-[16rem] text-sm leading-relaxed text-white/55">
								Tools for filmmakers.<br />
								Made on set. Trusted everywhere.
							</p>
							<div class="mt-4 flex flex-wrap gap-2">
								<a
									class="grid h-9 w-9 place-items-center rounded-lg border border-white/10 bg-black/35 text-white/55 transition hover:border-white/20 hover:text-white"
									href="https://www.youtube.com/@cinema-anamorphiclens6078"
									target="_blank"
									rel="noopener noreferrer"
									aria-label="YouTube"
								>
									<svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
										<path
											d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.9 3.5 12 3.5 12 3.5s-7.9 0-9.4.6A3 3 0 0 0 .5 6.2 31.7 31.7 0 0 0 0 12a31.7 31.7 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.5.6 9.4.6 9.4.6s7.9 0 9.4-.6a3 3 0 0 0 2.1-2.1 31.7 31.7 0 0 0 .5-5.8 31.7 31.7 0 0 0-.5-5.8ZM9.75 15.02V8.98L15.5 12l-5.75 3.02Z"
										/>
									</svg>
								</a>
								<a
									class="grid h-9 w-9 place-items-center rounded-lg border border-white/10 bg-black/35 text-white/55 transition hover:border-white/20 hover:text-white"
									href="#"
									aria-label="Instagram"
								>
									<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
										<rect x="3" y="3" width="18" height="18" rx="5" ry="5" />
										<circle cx="12" cy="12" r="4.25" />
										<circle cx="17.25" cy="6.75" r="1.2" fill="currentColor" stroke="none" />
									</svg>
								</a>
								<a
									class="grid h-9 w-9 place-items-center rounded-lg border border-white/10 bg-black/35 text-white/55 transition hover:border-white/20 hover:text-white"
									href="#"
									aria-label="X"
								>
									<svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
										<path
											d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
										/>
									</svg>
								</a>
							</div>
						</div>
					</div>
				</div>

				<div>
					<p class="text-[11px] font-semibold uppercase tracking-widest text-[#FF7A1A]">Products</p>
					<ul class="mt-4 space-y-2.5 text-sm">
						<li><a class="text-white/60 transition hover:text-white" href="/#suite-apps">FilmStudio</a></li>
						<li><a class="text-white/60 transition hover:text-white" href="/#suite-apps">Anamorphic Desqueezer</a></li>
						<li><a class="text-white/60 transition hover:text-white" href="/#suite-apps">CineLut Live Grade</a></li>
						<li><a class="text-white/60 transition hover:text-white" href="/#suite-apps">MediaUtility</a></li>
						<li><a class="text-white/60 transition hover:text-white" href="/#suite-apps">All Apps</a></li>
					</ul>
				</div>

				<div>
					<p class="text-[11px] font-semibold uppercase tracking-widest text-[#FF7A1A]">Company</p>
					<ul class="mt-4 space-y-2.5 text-sm">
						<li><a class="text-white/60 transition hover:text-white" href="#">About Us</a></li>
						<li><a class="text-white/60 transition hover:text-white" href="#">Careers</a></li>
						<li><a class="text-white/60 transition hover:text-white" href="/#contact">Contact</a></li>
						<li><a class="text-white/60 transition hover:text-white" href="#">Press Kit</a></li>
					</ul>
				</div>

				<div>
					<p class="text-[11px] font-semibold uppercase tracking-widest text-[#FF7A1A]">Resources</p>
					<ul class="mt-4 space-y-2.5 text-sm">
						<li><a class="text-white/60 transition hover:text-white" href="#">Documentation</a></li>
						<li><a class="text-white/60 transition hover:text-white" href="/guides">Guides</a></li>
						<li><a class="text-white/60 transition hover:text-white" href="#">Support</a></li>
						<li><a class="text-white/60 transition hover:text-white" href="#">Blog</a></li>
					</ul>
				</div>

				<div class="sm:col-span-2 lg:col-span-1">
					<p class="text-[11px] font-semibold uppercase tracking-widest text-[#FF7A1A]">Stay in the loop</p>
					<p class="mt-3 max-w-xs text-sm leading-relaxed text-white/55">
						Tips, updates, and filmmaker resources sent to your inbox.
					</p>
					<form class="mt-4" aria-label="Newsletter signup (preview only)">
						<div class="flex items-center gap-1 rounded-xl border border-white/10 bg-black/40 py-1 pl-3 pr-1 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
							<label class="sr-only" for="footer-email">Email address</label>
							<input
								id="footer-email"
								class="min-w-0 flex-1 bg-transparent py-2 text-sm text-white outline-none placeholder:text-white/40"
								type="email"
								name="email"
								autocomplete="email"
								placeholder="Enter your email"
							/>
							<button
								type="button"
								class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg text-[#FF7A1A] transition hover:bg-white/[0.06] hover:text-[#ff8f3d] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#FF7A1A]/45"
								aria-label="Submit email (coming soon)"
							>
								<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
									<path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round" />
								</svg>
							</button>
						</div>
					</form>
				</div>
			</div>

			<div class="mt-10 flex flex-col gap-4 border-t border-white/10 pt-6 text-xs text-white/55 sm:flex-row sm:items-center sm:justify-between sm:gap-6">
				<p class="shrink-0">© {new Date().getFullYear()} DeSqueeze Studio. All rights reserved.</p>
				<div class="flex flex-wrap items-center gap-x-1 gap-y-2 sm:justify-end">
					<a class="px-2 text-white/55 transition first:pl-0 hover:text-white sm:px-3" href="#">Privacy Policy</a>
					<span class="text-white/20" aria-hidden="true">|</span>
					<a class="px-2 text-white/55 transition hover:text-white sm:px-3" href="#">Terms of Use</a>
					<span class="text-white/20" aria-hidden="true">|</span>
					<a class="px-2 text-white/55 transition hover:text-white sm:px-3 last:pr-0" href="#">Cookie Policy</a>
				</div>
			</div>
		</div>
	</footer>
</div>


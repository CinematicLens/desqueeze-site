---
type Variant = 'desktop' | 'mobile';

interface Props {
	variant?: Variant;
}

const { variant = 'desktop' } = Astro.props;

const items = [
	{ label: 'How to Desqueeze 1.33x', short: '1.33x', href: '/how-to-desqueeze-1-33x' },
	{ label: 'How to Desqueeze 1.5x', short: '1.5x', href: '/how-to-desqueeze-1-5x' },
	{ label: 'Fix Stretched Video', short: 'Fix Video', href: '/fix-stretched-video' },
	{ label: 'Desqueeze Video Online', short: 'Online Tool', href: '/desqueeze-video-online' },
];

const normalize = (p: string) => (p || '/').replace(/\/+$/, '') || '/';
const currentPath = normalize(Astro.url?.pathname ?? '/');
const isActive = (href: string) => normalize(href) === currentPath;

const baseLink =
	'flex w-full items-center justify-between gap-3 rounded-xl border px-3 py-2 text-sm font-semibold transition focus:outline-none focus:ring-2 focus:ring-[var(--color-accent-border)]';
const idleLink = `${baseLink} border-[var(--color-border)] bg-[var(--color-surface-strong)] text-[var(--color-muted)] hover:bg-[var(--color-surface)] hover:text-[var(--color-text)]`;
const activeLink =
	`${baseLink} border-[var(--color-accent-30)] bg-[var(--color-accent-soft)] text-[var(--color-text)] shadow-[0_0_0_1px_var(--color-accent-12),0_0_22px_var(--color-accent-08)]`;
---

{variant === 'desktop' ? (
	<aside class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-4 shadow-[0_22px_70px_rgba(0,0,0,0.55)]">
		<p class="text-xs font-semibold tracking-[0.22em] text-[var(--color-muted-faint)]">GUIDES</p>

		<nav class="mt-4 flex flex-col gap-2" aria-label="Guides navigator">
			{items.map((item) => (
				<a class={isActive(item.href) ? activeLink : idleLink} href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
					<span class="min-w-0 truncate">{item.label}</span>
					<span class="shrink-0 text-xs font-semibold text-[var(--color-muted-faint)]">→</span>
				</a>
			))}
		</nav>

		<div class="mt-4 border-t border-[var(--color-border)] pt-4">
			<a
				href="/try-live"
				class="inline-flex w-full items-center justify-center rounded-xl border border-[var(--color-accent-border)] bg-[var(--color-accent-soft)] px-3 py-2 text-sm font-semibold text-[var(--color-accent)] hover:bg-[var(--color-accent-15)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent-border)]"
			>
				Try Live Tool
			</a>
		</div>
	</aside>
) : (
	<nav class="mt-5 lg:hidden" aria-label="Guides navigator">
		<div class="-mx-1.5 overflow-x-auto px-1.5 [scrollbar-width:thin] [scrollbar-color:var(--color-accent-border)_var(--color-scroll-track)]">
			<div class="flex w-max items-center gap-2 pb-1.5">
				{items.map((item) => (
					<a
						href={item.href}
						aria-current={isActive(item.href) ? 'page' : undefined}
						class={
							isActive(item.href)
								? 'inline-flex items-center rounded-full border border-[var(--color-accent-border)] bg-[var(--color-accent-soft)] px-3.5 py-1.5 text-xs font-semibold text-[var(--color-accent)] shadow-[0_0_0_1px_var(--color-accent-12)]'
								: 'inline-flex items-center rounded-full border border-[var(--color-border)] bg-[var(--color-surface-strong)] px-3.5 py-1.5 text-xs font-semibold text-[var(--color-muted)] hover:bg-[var(--color-surface)]'
						}
					>
						{item.short}
					</a>
				))}
				<a
					href="/try-live"
					class="inline-flex items-center rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] px-3.5 py-1.5 text-xs font-semibold text-[var(--color-muted)] hover:bg-[var(--color-surface-strong)]"
				>
					Try Live
				</a>
			</div>
		</div>
	</nav>
)}
